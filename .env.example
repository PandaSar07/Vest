# Reference template for production environment variables.
# ASP.NET Core maps Section__Key to Section:Key in configuration.
#
# Vercel: do NOT upload this file. In the Vercel dashboard go to
# Project Settings -> Environment Variables and add each variable below.
# You can also bulk-import with the Vercel CLI: vercel env pull / vercel env add
#
# Recommended hosts for this app: Railway, Render, Fly.io, or Azure App Service.
# Vest uses background services (limit orders, risk monitor) that need a always-on
# server process; serverless-only platforms are a poor fit.

ASPNETCORE_ENVIRONMENT=Production

# Required — restrict to your domain(s), semicolon-separated
AllowedHosts=yourdomain.com;www.yourdomain.com

# Finnhub
Finnhub__ApiKey=

# Supabase (rotate keys if they were ever committed to git)
Supabase__Url=
Supabase__AnonKey=
Supabase__ServiceRoleKey=

# Google OAuth (add https://yourdomain.com/signin-google as redirect URI)
Authentication__Google__ClientId=
Authentication__Google__ClientSecret=

# Email (Gmail app password recommended)
Email__SmtpHost=smtp.gmail.com
Email__SmtpPort=587
Email__Username=
Email__Password=
Email__From=
Email__FromName=Vest

# Web push notifications
Vapid__Subject=mailto:you@example.com
Vapid__PublicKey=
Vapid__PrivateKey=

# Optional
Vest__PublicContactEmail=
