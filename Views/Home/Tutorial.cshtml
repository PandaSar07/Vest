                <div class="checklist-card" role="checkbox" aria-checked="false" tabindex="0" data-checklist-item>
                    <div class="checklist-box" aria-hidden="true">
                        <svg class="checklist-tick" viewBox="0 0 12 12"><polyline points="2,6 5,9 10,3"/></svg>
                    </div>
                    <span class="checklist-text">Have I added the stock to my Watchlist first to observe it?</span>
