@{
    ViewData["Title"] = "Vest | Learning Hub — Invest Smarter";
    ViewData["MetaDescription"] = "New to investing? Learn the basics of stocks, key investing terms, and how to use Vest — all in one place. No jargon, just clarity.";
}

<style>
    /* Reading progress bar */
    #readingProgress {
        position: fixed;
        top: 0;
        left: 0;
        width: 0%;
        height: 3px;
        background: linear-gradient(90deg, #38bdf8, #818cf8);
        z-index: 9999;
        transition: width 0.1s linear;
        border-radius: 0 2px 2px 0;
        box-shadow: 0 0 8px rgba(56, 189, 248, 0.6);
    }
    .landing-shell {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1rem 5rem;
        position: relative;
        overflow: hidden;
    }

    .landing-orb {
        position: absolute;
        width: 360px;
        height: 360px;
        border-radius: 50%;
        filter: blur(60px);
        pointer-events: none;
        z-index: 0;
        opacity: 0.3;
        animation: drift 16s ease-in-out infinite;
    }

    .landing-orb-a {
        top: -120px;
        left: -140px;
        background: rgba(56, 189, 248, 0.45);
    }

    .landing-orb-b {
        top: 520px;
        right: -180px;
        background: rgba(168, 85, 247, 0.35);
        animation-delay: -6s;
    }

    .landing-orb-c {
        bottom: 120px;
        left: 32%;
        background: rgba(14, 165, 233, 0.22);
        animation-delay: -10s;
    }

    .landing-content {
        position: relative;
        z-index: 1;
    }

    .landing-hero {
        position: relative;
        border: 1px solid rgba(56, 189, 248, 0.2);
        border-radius: 28px;
        background:
            radial-gradient(circle at 15% 20%, rgba(56, 189, 248, 0.16), transparent 45%),
            radial-gradient(circle at 85% 85%, rgba(14, 165, 233, 0.12), transparent 45%),
            rgba(17, 25, 40, 0.7);
        backdrop-filter: blur(16px);
        overflow: hidden;
        padding: 3.25rem 2rem;
        box-shadow: 0 30px 80px -40px rgba(56, 189, 248, 0.3);
    }

    .landing-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        border: 1px solid rgba(56, 189, 248, 0.3);
        background: rgba(56, 189, 248, 0.1);
        color: var(--accent-color);
        font-size: 0.8rem;
        font-weight: 700;
        border-radius: 999px;
        padding: 0.45rem 0.9rem;
        margin-bottom: 1.25rem;
    }

    .landing-badge-dot {
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: var(--accent-color);
        box-shadow: 0 0 14px rgba(56, 189, 248, 0.8);
        animation: pulseDot 2s ease-in-out infinite;
    }

    .landing-title {
        font-size: clamp(2.25rem, 6vw, 4.2rem);
        line-height: 1.05;
        margin: 0;
    }

    .landing-subtitle {
        max-width: 620px;
        margin: 1rem 0 0;
        color: var(--text-secondary);
        font-size: 1.02rem;
    }

    .landing-hero-actions {
        margin-top: 1.8rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    .landing-mini-note {
        margin-top: 0.95rem;
        font-size: 0.83rem;
        color: var(--text-secondary);
    }

    .landing-proof {
        margin-top: 2rem;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.75rem;
    }

    .landing-proof-card {
        border: 1px solid var(--glass-border);
        border-radius: 14px;
        padding: 0.85rem 0.95rem;
        background: rgba(5, 7, 10, 0.4);
        transition: transform 0.25s ease, border-color 0.25s ease;
    }

    .landing-proof-card:hover {
        transform: translateY(-2px);
        border-color: rgba(56, 189, 248, 0.35);
    }

    .landing-proof-value {
        font-weight: 800;
        font-size: 1.05rem;
        color: var(--text-primary);
    }

    .landing-proof-label {
        color: var(--text-secondary);
        font-size: 0.8rem;
    }

    .landing-section {
        margin-top: 2.5rem;
        scroll-margin-top: 96px;
    }

    .landing-section-title {
        font-size: clamp(1.6rem, 3vw, 2.2rem);
        margin-bottom: 0.45rem;
    }

    .landing-section-copy {
        color: var(--text-secondary);
        max-width: 680px;
    }

    .landing-grid {
        margin-top: 1rem;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
    }

    .landing-card {
        border: 1px solid var(--glass-border);
        border-radius: 18px;
        background: rgba(17, 25, 40, 0.66);
        padding: 1.1rem;
        transition: var(--transition);
    }

    .landing-card:hover {
        border-color: rgba(56, 189, 248, 0.35);
    }

    .landing-card h3 {
        font-size: 1.05rem;
        margin-bottom: 0.45rem;
    }

    .landing-card p {
        margin: 0;
        color: var(--text-secondary);
        font-size: 0.92rem;
    }

    .landing-logos {
        margin-top: 1rem;
        display: grid;
        grid-template-columns: repeat(6, minmax(0, 1fr));
        gap: 0.75rem;
    }

    .landing-logo-chip {
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        text-align: center;
        font-weight: 700;
        font-size: 0.85rem;
        padding: 0.7rem 0.6rem;
        background: rgba(17, 25, 40, 0.52);
        color: #cbd5e1;
        letter-spacing: 0.2px;
    }

    .landing-stat-grid {
        margin-top: 1rem;
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.9rem;
    }

    .landing-stat {
        border: 1px solid var(--glass-border);
        border-radius: 14px;
        padding: 1rem;
        background: rgba(17, 25, 40, 0.6);
    }

    .landing-stat-value {
        font-size: clamp(1.7rem, 4vw, 2.3rem);
        font-weight: 800;
        line-height: 1;
        color: var(--text-primary);
    }

    .landing-stat-label {
        margin-top: 0.35rem;
        color: var(--text-secondary);
        font-size: 0.85rem;
    }

    .landing-split {
        margin-top: 1rem;
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 1rem;
    }

    .landing-panel {
        border: 1px solid var(--glass-border);
        border-radius: 18px;
        padding: 1.2rem;
        background: rgba(17, 25, 40, 0.62);
    }

    .landing-panel h3 {
        font-size: 1.05rem;
        margin-bottom: 0.55rem;
    }

    .landing-list {
        margin: 0;
        padding-left: 1.1rem;
        color: var(--text-secondary);
    }

    .landing-list li {
        margin-bottom: 0.45rem;
    }

    /* Glossary */
    .glossary-grid {
        margin-top: 1rem;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.9rem;
    }

    .glossary-term {
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        background: rgba(17, 25, 40, 0.62);
        padding: 1rem 1.1rem;
        transition: var(--transition);
    }

    .glossary-term:hover {
        border-color: rgba(56, 189, 248, 0.35);
        transform: translateY(-2px);
    }

    .glossary-term-label {
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent-color);
        margin-bottom: 0.3rem;
    }

    .glossary-term h4 {
        font-size: 1rem;
        margin: 0 0 0.4rem;
    }

    .glossary-term p {
        margin: 0;
        font-size: 0.88rem;
        color: var(--text-secondary);
    }

    @@media (max-width: 992px) {
        .glossary-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 768px) {
        .glossary-grid {
            grid-template-columns: 1fr;
        }
    }

    .landing-steps {
        margin-top: 1rem;
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.9rem;
    }

    .landing-step {
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        background: rgba(17, 25, 40, 0.58);
        padding: 1rem;
    }

    .landing-step-num {
        width: 1.7rem;
        height: 1.7rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(56, 189, 248, 0.12);
        border: 1px solid rgba(56, 189, 248, 0.3);
        font-weight: 700;
        font-size: 0.8rem;
        color: var(--accent-color);
        margin-bottom: 0.5rem;
    }

    .landing-step h4 {
        font-size: 0.98rem;
        margin-bottom: 0.35rem;
    }

    .landing-step p {
        margin: 0;
        font-size: 0.88rem;
        color: var(--text-secondary);
    }

    .landing-testimonial-grid {
        margin-top: 1rem;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
    }

    .landing-testimonial {
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        background: rgba(17, 25, 40, 0.6);
        padding: 1rem;
    }

    .landing-testimonial-copy {
        margin: 0;
        color: #dbeafe;
        font-size: 0.92rem;
    }

    .landing-testimonial-meta {
        margin-top: 0.8rem;
        color: var(--text-secondary);
        font-size: 0.82rem;
    }

    .landing-faq {
        margin-top: 1rem;
        display: grid;
        gap: 0.8rem;
    }

    .landing-faq-item {
        border: 1px solid var(--glass-border);
        border-radius: 14px;
        background: rgba(17, 25, 40, 0.56);
        padding: 1rem;
    }

    .landing-faq-item h4 {
        font-size: 0.98rem;
        margin-bottom: 0.4rem;
    }

    .landing-faq-item p {
        margin: 0;
        color: var(--text-secondary);
        font-size: 0.9rem;
    }

    /* Interactive checklist cards */
    .checklist-grid {
        margin-top: 1rem;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 0.8rem;
    }

    .checklist-card {
        display: flex;
        align-items: flex-start;
        gap: 0.85rem;
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        background: rgba(17, 25, 40, 0.62);
        padding: 1rem 1.1rem;
        cursor: pointer;
        user-select: none;
        transition: border-color 0.25s ease, background 0.25s ease, transform 0.2s ease;
    }

    .checklist-card:hover {
        border-color: rgba(56, 189, 248, 0.35);
        transform: translateY(-2px);
    }

    .checklist-card.checked {
        border-color: rgba(52, 211, 153, 0.5);
        background: rgba(52, 211, 153, 0.07);
    }

    .checklist-box {
        flex-shrink: 0;
        width: 1.45rem;
        height: 1.45rem;
        border-radius: 50%;
        border: 2px solid rgba(100, 116, 139, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: border-color 0.25s ease, background 0.25s ease;
        margin-top: 0.1rem;
    }

    .checklist-card.checked .checklist-box {
        border-color: rgba(52, 211, 153, 0.8);
        background: rgba(52, 211, 153, 0.18);
    }

    .checklist-tick {
        display: none;
        width: 0.7rem;
        height: 0.7rem;
        stroke: #34d399;
        stroke-width: 3;
        fill: none;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .checklist-card.checked .checklist-tick {
        display: block;
    }

    .checklist-text {
        font-size: 0.92rem;
        color: var(--text-secondary);
        line-height: 1.45;
        transition: color 0.25s ease;
    }

    .checklist-card.checked .checklist-text {
        color: #cbd5e1;
    }

    .checklist-progress {
        margin-top: 1rem;
        font-size: 0.82rem;
        color: var(--text-secondary);
    }

    .checklist-progress-bar-wrap {
        margin-top: 0.4rem;
        height: 4px;
        border-radius: 99px;
        background: rgba(100, 116, 139, 0.2);
        overflow: hidden;
    }

    .checklist-progress-bar {
        height: 100%;
        border-radius: 99px;
        background: linear-gradient(90deg, #34d399, #38bdf8);
        transition: width 0.35s ease;
    }

    .landing-final-cta {
        margin-top: 2rem;
        border: 1px solid rgba(56, 189, 248, 0.24);
        border-radius: 22px;
        background: linear-gradient(145deg, rgba(56, 189, 248, 0.13), rgba(17, 25, 40, 0.7));
        padding: 2rem 1.1rem;
        text-align: center;
    }

    .landing-final-cta p {
        color: var(--text-secondary);
        max-width: 620px;
        margin: 0.7rem auto 1.2rem;
    }

    .reveal {
        opacity: 0;
        transform: translateY(28px);
        transition: opacity 0.75s ease, transform 0.75s ease;
    }

    .reveal.in-view {
        opacity: 1;
        transform: translateY(0);
    }

    @@keyframes drift {
        0%, 100% { transform: translateY(0) translateX(0) scale(1); }
        50% { transform: translateY(20px) translateX(16px) scale(1.08); }
    }

    @@keyframes pulseDot {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.6; transform: scale(1.2); }
    }

    @@media (max-width: 992px) {
        .landing-logos {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
        .landing-stat-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
        .landing-split {
            grid-template-columns: 1fr;
        }
        .landing-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
        .landing-steps {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
        .landing-testimonial-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 768px) {
        .landing-hero {
            padding: 2.2rem 1.1rem;
        }
        .landing-proof {
            grid-template-columns: 1fr;
        }
        .landing-grid,
        .landing-steps {
            grid-template-columns: 1fr;
        }
        .landing-stat-grid,
        .landing-logos {
            grid-template-columns: 1fr;
        }
    }

    @@media (prefers-reduced-motion: reduce) {
        .landing-orb,
        .landing-badge-dot {
            animation: none;
        }
        .reveal {
            opacity: 1;
            transform: none;
            transition: none;
        }
    }
</style>

<div id="readingProgress" role="progressbar" aria-label="Reading progress" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>

<div class="landing-shell">
    <div class="landing-orb landing-orb-a"></div>
    <div class="landing-orb landing-orb-b"></div>
    <div class="landing-orb landing-orb-c"></div>

    <div class="landing-content">
        <section class="landing-hero reveal">
            <div class="landing-badge"><span class="landing-badge-dot"></span>Getting Started</div>
            <h1 class="landing-title">
                Learn investing without<br />the jargon.
            </h1>
            <p class="landing-subtitle">
                This is your new home base for learning and doing. Before you jump into screening symbols or building a portfolio, here is a simple walkthrough of the basics and how Vest works.
            </p>
            <div class="landing-hero-actions">
                <a asp-controller="Stocks" asp-action="Index" class="btn btn-primary btn-lg px-4 rounded-pill">Start Exploring</a>
            </div>
            <p class="landing-mini-note">No hype. Just a clear process you can actually follow.</p>
        </section>

        <section class="landing-section reveal">
            <h2 class="landing-section-title" id="learn">What are stocks, really?</h2>
            <p class="landing-section-copy">
                Investing can feel overwhelming at first, but the core idea is simple.
            </p>
            <div class="landing-split">
                <article class="landing-panel">
                    <h3>You own a tiny piece of a company</h3>
                    <p class="landing-list">
                        When you buy a stock, you are buying a small ownership stake in a public company.
                        If that company grows over time, your shares can grow in value too.
                        So instead of only using products from companies like Apple or Microsoft, you can own part of them.
                    </p>
                </article>
                <article class="landing-panel">
                    <h3>How people make money with stocks</h3>
                    <ul class="landing-list">
                        <li><strong>Price growth:</strong> If the company becomes more valuable, your shares usually rise too. You lock in profit when you sell above your buy price.</li>
                        <li><strong>Dividends:</strong> Some companies pay cash to shareholders on a regular schedule, often every quarter.</li>
                        <li><strong>Risk:</strong> Prices move up and down with earnings, news, and market mood. If you sell during a drop, you can take a loss.</li>
                    </ul>
                </article>
            </div>
        </section>

        <section class="landing-section reveal">
            <h2 class="landing-section-title">How to use Vest day to day</h2>
            <p class="landing-section-copy">
                Here is what each area does, in plain English.
            </p>
            <div class="landing-grid">
                <article class="landing-card">
                    <h3>Home / Dashboard</h3>
                    <p>Your command center. You will see your progress, recent market movement, and shortcuts to what you care about most.</p>
                </article>
                <article class="landing-card">
                    <h3>Stocks Screener</h3>
                    <p>Filter thousands of stocks by metrics like market cap, price, and volume so you can narrow down ideas fast.</p>
                </article>
                <article class="landing-card">
                    <h3>Watchlist</h3>
                    <p>Not ready to buy yet? Save symbols here and keep an eye on them before committing money.</p>
                </article>
                <article class="landing-card">
                    <h3>Portfolio</h3>
                    <p>Track your real positions and see how your gains and losses change over time.</p>
                </article>
                <article class="landing-card">
                    <h3>Learning Hub (you are here)</h3>
                    <p>This page is your built-in guide. Come back anytime when you want a quick refresher before making decisions.</p>
                </article>
                <article class="landing-card">
                    <h3>Account Settings</h3>
                    <p>Manage your profile, security options like 2FA, and preferences like dark mode.</p>
                </article>
            </div>
        </section>

        <section class="landing-section reveal">
            <h2 class="landing-section-title">Key Investing Terms</h2>
            <p class="landing-section-copy">
                New to investing? Here are plain-English definitions for the terms you'll come across most often on Vest.
            </p>
            <div class="glossary-grid">
                <div class="glossary-term">
                    <div class="glossary-term-label">Order Type</div>
                    <h4>Market Order</h4>
                    <p>An instruction to buy or sell a stock immediately at the current market price. Fast, but you get whatever price the market is at that moment.</p>
                </div>
                <div class="glossary-term">
                    <div class="glossary-term-label">Order Type</div>
                    <h4>Limit Order</h4>
                    <p>An order to buy or sell only at a specific price (or better). Gives you price control, but the trade may not execute if the market never hits your target.</p>
                </div>
                <div class="glossary-term">
                    <div class="glossary-term-label">Your Account</div>
                    <h4>Portfolio Value</h4>
                    <p>The total current worth of all the investments you hold. It rises and falls with the market prices of the stocks in your portfolio.</p>
                </div>
                <div class="glossary-term">
                    <div class="glossary-term-label">Returns</div>
                    <h4>Dividend</h4>
                    <p>A cash payment some companies send to shareholders, usually quarterly. It's a share of the company's profits given back to investors who hold the stock.</p>
                </div>
                <div class="glossary-term">
                    <div class="glossary-term-label">Company Size</div>
                    <h4>Market Cap</h4>
                    <p>Short for "market capitalization" — the total value of all a company's shares. Large-cap companies (e.g. Apple) are generally more stable than small-caps.</p>
                </div>
                <div class="glossary-term">
                    <div class="glossary-term-label">Market Mood</div>
                    <h4>Bull vs. Bear Market</h4>
                    <p>A <strong>bull market</strong> is a period of rising prices and optimism. A <strong>bear market</strong> is a prolonged decline of 20% or more — a good time to stay calm and think long-term.</p>
                </div>
            </div>
        </section>

        <section class="landing-section reveal">
            <h2 class="landing-section-title">A simple 4-step investing process</h2>
            <p class="landing-section-copy">
                Skip the guessing and follow the same process each time.
            </p>
            <div class="landing-steps">
                <div class="landing-step">
                    <div class="landing-step-num">1</div>
                    <h4>Educate</h4>
                    <p>Know what the company actually does before you buy anything.</p>
                </div>
                <div class="landing-step">
                    <div class="landing-step-num">2</div>
                    <h4>Filter</h4>
                    <p>Use the Vest screener to compare similar companies and find the strongest candidates.</p>
                </div>
                <div class="landing-step">
                    <div class="landing-step-num">3</div>
                    <h4>Monitor</h4>
                    <p>Add your top picks to your watchlist and wait for an entry that matches your risk level.</p>
                </div>
                <div class="landing-step">
                    <div class="landing-step-num">4</div>
                    <h4>Execute</h4>
                    <p>Once you invest, track it in your portfolio and review what worked (and what did not).</p>
                </div>
            </div>
        </section>

        <section class="landing-section reveal" id="checklist">
            <h2 class="landing-section-title">Before you invest: quick checklist</h2>
            <p class="landing-section-copy">
                Tap each card to check it off. These habits help more than any hot tip.
            </p>
            <div class="checklist-grid" id="preTradeChecklist" role="group" aria-label="Pre-trade checklist">
                <div class="checklist-card" role="checkbox" aria-checked="false" tabindex="0" data-checklist-item>
                    <div class="checklist-box" aria-hidden="true">
                        <svg class="checklist-tick" viewBox="0 0 12 12"><polyline points="2,6 5,9 10,3"/></svg>
                    </div>
                    <span class="checklist-text">Do I understand what this company actually does?</span>
                </div>
                <div class="checklist-card" role="checkbox" aria-checked="false" tabindex="0" data-checklist-item>
                    <div class="checklist-box" aria-hidden="true">
                        <svg class="checklist-tick" viewBox="0 0 12 12"><polyline points="2,6 5,9 10,3"/></svg>
                    </div>
                    <span class="checklist-text">Have I checked the stock's recent performance and key metrics?</span>
                </div>
                <div class="checklist-card" role="checkbox" aria-checked="false" tabindex="0" data-checklist-item>
                    <div class="checklist-box" aria-hidden="true">
