</div>

<script>
    (() => {
        // --- Scroll reveal ---
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const revealEls = Array.from(document.querySelectorAll('.reveal'));

        if (!reduced && 'IntersectionObserver' in window) {
            const revealObserver = new IntersectionObserver((entries, obs) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('in-view');
                        obs.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.16, rootMargin: '0px 0px -8% 0px' });

            revealEls.forEach(el => revealObserver.observe(el));
        } else {
            revealEls.forEach(el => el.classList.add('in-view'));
        }

        // --- Reading progress bar ---
        const progressBar = document.getElementById('readingProgress');
        function updateProgress() {
            const scrollTop  = window.scrollY;
            const docHeight  = document.documentElement.scrollHeight - window.innerHeight;
            const pct        = docHeight > 0 ? Math.min(100, (scrollTop / docHeight) * 100) : 0;
            progressBar.style.width = pct + '%';
            progressBar.setAttribute('aria-valuenow', Math.round(pct));
        }
        window.addEventListener('scroll', updateProgress, { passive: true });
        updateProgress();

        // --- Interactive pre-trade checklist ---
        const cards   = Array.from(document.querySelectorAll('[data-checklist-item]'));
        const countEl = document.getElementById('checklistCount');
        const barEl   = document.getElementById('checklistBar');
        const total   = cards.length;

        function updateProgress() {
            const done = cards.filter(c => c.classList.contains('checked')).length;
            countEl.textContent = `${done} / ${total} completed`;
            barEl.style.width   = `${(done / total) * 100}%`;
        }

        function toggleCard(card) {
            const isChecked = card.classList.toggle('checked');
            card.setAttribute('aria-checked', String(isChecked));
            updateProgress();
        }

        cards.forEach(card => {
            card.addEventListener('click', () => toggleCard(card));
            card.addEventListener('keydown', e => {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    toggleCard(card);
                }
            });
        });
    })();
</script>
