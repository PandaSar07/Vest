@{
    ViewData["Title"] = "Vest | Invest Smarter";
}

<!-- HERO -->
<div class="hero-section">
    <div class="hero-glow"></div>
    <div class="hero-badge">Invest Smarter</div>
    <h1 class="hero-title">Vest</h1>
    <p class="hero-subtitle">
        Vest helps new investors understand the stock and crypto markets using
        data-driven insights, quantitative analysis, and clear explanations —
        no hype, no guesswork.
    </p>
    <div class="d-flex flex-wrap justify-content-center gap-3">
        <a asp-controller="Stocks" asp-action="Index" class="btn btn-primary btn-lg px-5 py-3 rounded-pill shadow-lg">Explore markets</a>
        <a asp-controller="Home" asp-action="Signup" class="btn btn-outline btn-lg px-5 py-3 rounded-pill">Create free account</a>
    </div>
    <p class="mt-4 mb-0 text-secondary small">
        Already have an account?
        <a asp-controller="Home" asp-action="Log" class="forgot-link text-decoration-none fw-semibold">Log in</a>
        <span class="text-secondary mx-1">·</span>
        <a asp-controller="Home" asp-action="About" class="forgot-link text-decoration-none fw-semibold">About Vest</a>
    </p>
</div>

<!-- WHAT WE DO -->
<div class="section text-center">
    <h2 class="section-title">What Vest Does</h2>
    <p class="mx-auto" style="max-width: 800px;">
        Vest is an educational, quantitative investing platform designed for beginners.
        We break down market data, trends, and strategies so you can learn how markets work
        before making real decisions.
    </p>
</div>

<!-- WHY VEST -->
<div class="section">
    <div class="container">
        <h2 class="section-title text-center">Why Vest?</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 p-4 text-center">
                    <h4>Quantitative Focus</h4>
                    <p>
                        Learn how data, statistics, and models are used to analyze markets —
                        the same tools professionals rely on.
                    </p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 p-4 text-center">
                    <h4>Beginner Friendly</h4>
                    <p>
                        No prior investing knowledge required. Concepts are explained clearly
                        with real-world examples.
                    </p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 p-4 text-center">
                    <h4>Smarter Decisions</h4>
                    <p>
                        Vest focuses on understanding risk, probability, and long-term thinking —
                        not short-term speculation.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- FEATURES PREVIEW -->
<div class="section text-center">
    <h2 class="section-title">What You'll Find on Vest</h2>
    <div class="row g-4 justify-content-center">
        <div class="col-md-3">
             <div class="card h-100 p-4 border-0 text-center fw-bold text-gradient">
                Market Data Visualizations
             </div>
        </div>
        <div class="col-md-3">
             <div class="card h-100 p-4 border-0 text-center fw-bold text-gradient">
                Quant Models & Indicators
             </div>
        </div>
        <div class="col-md-3">
             <div class="card h-100 p-4 border-0 text-center fw-bold text-gradient">
                Beginner Investing Guides
             </div>
        </div>
        <div class="col-md-3">
             <div class="card h-100 p-4 border-0 text-center fw-bold text-gradient">
                Risk & Volatility Education
             </div>
        </div>
    </div>
</div>

<!-- CALL TO ACTION -->
<div class="cta-section text-center">
    <h2>New to investing?</h2>
    <p class="mb-4 text-secondary mx-auto" style="max-width:520px;">
        Browse stocks and crypto, use the screener, and save symbols to a watchlist — then sign in to track a portfolio on your dashboard.
    </p>
    <div class="d-flex flex-wrap justify-content-center gap-3">
        <a class="btn btn-primary btn-lg px-4 rounded-pill" asp-controller="Home" asp-action="Signup">Create free account</a>
        <a class="btn btn-outline btn-lg px-4 rounded-pill" asp-controller="Home" asp-action="Log">Log in</a>
    </div>
</div>

@* Homepage designed by Benson Xue *@
