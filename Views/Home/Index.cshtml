@{
    ViewData["Title"] = "Vest | Invest Smarter";
}

<!-- HERO -->
<div class="hero-section">
    <div class="hero-glow"></div>
    <div class="hero-badge">Invest Smarter</div>
    <h1 class="hero-title">Vest</h1>
    <p class="hero-subtitle">
        Vest helps new investors understand the stock and crypto markets using
        data-driven insights, quantitative analysis, and clear explanations —
        no hype, no guesswork.
    </p>
    <div class="d-flex justify-content-center gap-3">
        <a asp-controller="Learn" asp-action="Index" class="btn btn-primary btn-lg px-5 py-3 rounded-pill shadow-lg">Start Learning</a>
        <a asp-controller="Home" asp-action="About" class="btn btn-outline btn-lg px-5 py-3 rounded-pill">Learn More</a>
    </div>
</div>

<!-- WHAT WE DO -->
<div class="section text-center">
    <h2 class="section-title">What Is Vest?</h2>
    <p class="mx-auto" style="max-width: 800px;">
        Vest is an educational, quantitative investing platform designed for beginners.
        We break down market data, trends, and strategies so you can learn how markets work
        before making real decisions.
    </p>
</div>

<!-- WHY VEST -->
<div class="section">
    <div class="container">
        <h2 class="section-title text-center">Why Vest?</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 p-4 text-center">
                    <h4>Quantitative Focus</h4>
                    <p>
                        Learn how data, statistics, and models are used to analyze markets —
                        the same tools professionals rely on.
                    </p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 p-4 text-center">
                    <h4>Beginner Friendly</h4>
                    <p>
                        No prior investing knowledge required. Concepts are explained clearly
                        with real-world examples.
                    </p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 p-4 text-center">
                    <h4>Smarter Decisions</h4>
                    <p>
                        Vest focuses on understanding risk, probability, and long-term thinking —
                        not short-term speculation.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- FEATURES PREVIEW -->
<div class="section text-center">
    <h2 class="section-title">What You'll Find on Vest</h2>
    <div class="row g-4 justify-content-center">
        <div class="col-md-3">
             <div class="card h-100 p-4 border-0 text-center fw-bold text-gradient">
                Market Data Visualizations
             </div>
        </div>
        <div class="col-md-3">
             <div class="card h-100 p-4 border-0 text-center fw-bold text-gradient">
                Quant Models & Indicators
             </div>
        </div>
        <div class="col-md-3">
             <div class="card h-100 p-4 border-0 text-center fw-bold text-gradient">
                Beginner Investing Guides
             </div>
        </div>
        <div class="col-md-3">
             <div class="card h-100 p-4 border-0 text-center fw-bold text-gradient">
                Risk & Volatility Education
             </div>
        </div>
    </div>
</div>

<!-- CALL TO ACTION -->
<div class="cta-section text-center">
    <h2>New to Investing?</h2>
    <p class="mb-4">
        Start by learning how markets work before risking real money.
    </p>
    <a class="btn btn-dark" asp-controller="Learn" asp-action="Index">
        Start Learning
    </a>
</div>

<!-- FOOTER -->
<footer class="text-center mt-5 mb-3 text-muted">
    © @DateTime.Now.Year Vest • Educational purposes only • Not financial advice
</footer>

@* Homepage designed by Benson Xue *@
