@{
    ViewData["Title"] = "Contact";
    var publicEmail = ViewData["PublicContactEmail"] as string;
}

@section Head {
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            important: '#vest-marketing',
            corePlugins: { preflight: false },
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                        display: ['Orbitron', 'sans-serif'],
                    },
                },
            },
        };
    </script>
}

<div id="vest-marketing" class="vest-marketing min-h-screen bg-[#05070a] pb-24 text-slate-200 antialiased">
    <section class="relative overflow-hidden border-b border-white/10 px-4 pb-16 pt-16 sm:pt-20">
        <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(56,189,248,0.2),transparent)]"></div>
        <div class="relative mx-auto max-w-3xl text-center">
            <p data-anim="hero-line" class="font-display text-xs font-semibold uppercase tracking-[0.35em] text-sky-400/90">Contact</p>
            <h1 data-anim="hero-line" class="mt-3 font-display text-4xl font-bold text-white sm:text-5xl">Get in touch</h1>
            <p data-anim="hero-line" class="mx-auto mt-6 max-w-xl text-slate-400">
                Questions about Vest, this site, or your data? Use the options below. For account access problems, try
                <a class="text-sky-400 hover:text-sky-300" asp-controller="Home" asp-action="ForgotPassword">Forgot password</a>
                on the log in page.
            </p>
        </div>
    </section>

    <div class="mx-auto grid max-w-5xl gap-8 px-4 py-16 lg:grid-cols-2 lg:gap-10">
        <div data-anim="reveal" class="rounded-2xl border border-white/10 bg-[rgba(17,25,40,0.65)] p-8 backdrop-blur-md">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-sky-500/15 text-xl">✉️</div>
            <h2 class="mt-5 font-display text-lg font-semibold text-white">Email</h2>
            <p class="mt-2 text-sm text-slate-400">
                For general inquiries, partnerships, or privacy requests, send us a message.
            </p>
            @if (!string.IsNullOrEmpty(publicEmail))
            {
                <a class="mt-5 inline-flex items-center gap-2 text-sky-400 transition hover:text-sky-300" href="mailto:@publicEmail">
                    <span class="font-medium">@publicEmail</span>
                    <span aria-hidden="true">→</span>
                </a>
            }
            else
            {
                <p class="mt-5 rounded-xl border border-amber-500/25 bg-amber-500/10 px-4 py-3 text-sm text-amber-200/90">
                    Set <code class="rounded bg-black/30 px-1.5 py-0.5 text-xs text-amber-100">Vest:PublicContactEmail</code> in <code class="rounded bg-black/30 px-1.5 py-0.5 text-xs text-amber-100">appsettings.json</code> to show a public address here.
                </p>
            }
        </div>

        <div data-anim="reveal" class="rounded-2xl border border-white/10 bg-[rgba(17,25,40,0.65)] p-8 backdrop-blur-md">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-500/15 text-xl">📋</div>
            <h2 class="mt-5 font-display text-lg font-semibold text-white">Privacy &amp; data</h2>
            <p class="mt-2 text-sm text-slate-400">
                Read how we handle personal information, cookies, and your rights.
            </p>
            <a asp-controller="Home" asp-action="Privacy" class="mt-5 inline-flex items-center gap-2 font-medium text-sky-400 transition hover:text-sky-300">
                Privacy Policy
                <span aria-hidden="true">→</span>
            </a>
        </div>

        <div data-anim="reveal" class="rounded-2xl border border-white/10 bg-[rgba(17,25,40,0.65)] p-8 backdrop-blur-md lg:col-span-2">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-violet-500/15 text-xl">ℹ️</div>
            <h2 class="mt-5 font-display text-lg font-semibold text-white">Important notice</h2>
            <p class="mt-2 max-w-3xl text-sm text-slate-400">
                Vest is for <strong class="text-slate-300">educational use</strong> only. We do not provide personalized investment, legal, or tax advice.
                Market data may be delayed or incomplete depending on data providers and your configuration.
            </p>
            <div class="mt-6 flex flex-wrap gap-3">
                <a asp-controller="Home" asp-action="About" class="inline-flex rounded-xl border border-white/15 bg-white/5 px-5 py-2.5 text-sm font-semibold text-white transition hover:border-sky-500/35 hover:bg-white/10">About Vest</a>
                <a asp-controller="Home" asp-action="Index" class="inline-flex rounded-xl border border-white/15 bg-white/5 px-5 py-2.5 text-sm font-semibold text-white transition hover:border-sky-500/35 hover:bg-white/10">Home</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>
    <script>
        gsap.registerPlugin(ScrollTrigger);
        gsap.from('[data-anim="hero-line"]', {
            opacity: 0,
            y: 26,
            duration: 0.82,
            stagger: 0.1,
            ease: 'power3.out',
        });
        gsap.utils.toArray('[data-anim="reveal"]').forEach(function (el) {
            gsap.from(el, {
                opacity: 0,
                y: 30,
                duration: 0.7,
                ease: 'power2.out',
                scrollTrigger: { trigger: el, start: 'top 90%', toggleActions: 'play none none none' },
            });
        });
    </script>
}
