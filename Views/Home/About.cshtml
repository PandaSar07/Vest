@{
    ViewData["Title"] = "About";
    var featureCards = new (string Icon, string Title, string Body)[]
    {
        ("📊", "Markets & quotes", "Browse stocks and crypto with search and detail views backed by market data providers."),
        ("⭐", "Watchlists", "Save symbols you care about and keep them synced when you are signed in."),
        ("📈", "Market views", "Explore focused stock and crypto pages with live quote context and quick research tools."),
        ("🛡️", "Accounts & sessions", "Sign up and sign in with a secure password flow; sessions keep your experience consistent."),
        ("📰", "Context", "News and profile-style context to help you understand what you are looking at."),
        ("🎓", "Learning-first", "Vest is for education and personal organization—not personalized investment advice."),
    };
}

@section Head {
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            important: '#vest-marketing',
            corePlugins: { preflight: false },
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                        display: ['Orbitron', 'sans-serif'],
                    },
                },
            },
        };
    </script>
}

<div id="vest-marketing" class="vest-marketing min-h-screen bg-[#05070a] text-slate-200 antialiased">
    <section class="relative overflow-hidden border-b border-white/10 px-4 pb-20 pt-16 sm:pt-24">
        <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(56,189,248,0.22),transparent)]"></div>
        <div class="pointer-events-none absolute left-1/2 top-24 h-72 w-[42rem] -translate-x-1/2 rounded-full bg-sky-500/10 blur-3xl"></div>
        <div class="relative mx-auto max-w-4xl text-center">
            <p data-anim="hero-line" class="mb-4 font-display text-xs font-semibold uppercase tracking-[0.35em] text-sky-400/90">About Vest</p>
            <h1 data-anim="hero-line" class="font-display text-4xl font-bold tracking-tight text-white sm:text-5xl md:text-6xl">
                Clarity for your <span class="text-sky-400">portfolio</span>
            </h1>
            <p data-anim="hero-line" class="mx-auto mt-6 max-w-2xl text-lg text-slate-400">
                Vest is a portfolio and markets workspace built for learning and experimentation.
                Track US-focused equities and crypto, organize a watchlist, and explore tools in one calm interface.
            </p>
            <div data-anim="hero-line" class="mt-10 flex flex-wrap items-center justify-center gap-3">
                <span class="rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm text-slate-300 backdrop-blur-sm">Live market data</span>
                <span class="rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm text-slate-300 backdrop-blur-sm">Watchlists</span>
                <span class="rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm text-slate-300 backdrop-blur-sm">Educational use</span>
            </div>
        </div>
    </section>

    <section class="mx-auto max-w-6xl px-4 py-20">
        <div data-anim="reveal" class="mx-auto mb-14 max-w-2xl text-center">
            <p class="font-display text-xs font-semibold uppercase tracking-[0.3em] text-sky-400/90">What you can do</p>
            <h2 class="mt-3 font-display text-3xl font-bold text-white sm:text-4xl">Built for focus, not noise</h2>
            <p class="mt-4 text-slate-400">Practical tools for following markets—without pretending to be a brokerage.</p>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            @foreach (var c in featureCards)
            {
                <div data-anim="reveal" class="group rounded-2xl border border-white/10 bg-[rgba(17,25,40,0.6)] p-6 shadow-[0_20px_50px_-24px_rgba(0,0,0,0.7)] backdrop-blur-md transition duration-300 hover:border-sky-500/30 hover:shadow-[0_24px_60px_-20px_rgba(56,189,248,0.12)]">
                    <div class="mb-4 text-3xl opacity-90 transition group-hover:scale-110">@c.Icon</div>
                    <h3 class="font-display text-lg font-semibold text-white">@c.Title</h3>
                    <p class="mt-2 text-sm leading-relaxed text-slate-400">@c.Body</p>
                </div>
            }
        </div>
    </section>

    <section class="border-y border-white/10 bg-white/[0.02] px-4 py-20">
        <div class="mx-auto max-w-4xl">
            <div data-anim="reveal" class="text-center">
                <p class="font-display text-xs font-semibold uppercase tracking-[0.3em] text-sky-400/90">People</p>
                <h2 class="mt-3 font-display text-3xl font-bold text-white sm:text-4xl">Made by students, for curious investors</h2>
                <p class="mx-auto mt-4 max-w-xl text-slate-400">
                    Vest started as a passion project at Drexel University and continues to grow with design and engineering contributions from the team.
                </p>
            </div>
            <div class="mx-auto mt-12 grid max-w-5xl gap-6 sm:grid-cols-2 lg:grid-cols-4">
                <div data-anim="reveal" class="rounded-2xl border border-white/10 bg-[rgba(17,25,40,0.75)] p-7 text-center backdrop-blur-md">
                    <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-sky-500/15 text-2xl">🧑‍💻</div>
                    <h3 class="font-display font-semibold text-white">Sarvarbek Rahmonov</h3>
                    <p class="mt-1 text-sm text-slate-500">Lead developer</p>
                </div>
                <div data-anim="reveal" class="rounded-2xl border border-white/10 bg-[rgba(17,25,40,0.75)] p-7 text-center backdrop-blur-md">
                    <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-amber-500/15 text-2xl">🗄️</div>
                    <h3 class="font-display font-semibold text-white">Edison Zheng</h3>
                    <p class="mt-1 text-sm text-slate-500">Database manager</p>
                </div>
                <div data-anim="reveal" class="rounded-2xl border border-white/10 bg-[rgba(17,25,40,0.75)] p-7 text-center backdrop-blur-md">
                    <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-emerald-500/15 text-2xl">🎨</div>
                    <h3 class="font-display font-semibold text-white">Benson Xue</h3>
                    <p class="mt-1 text-sm text-slate-500">Frontend developer</p>
                </div>
                <div data-anim="reveal" class="rounded-2xl border border-white/10 bg-[rgba(17,25,40,0.75)] p-7 text-center backdrop-blur-md">
                    <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-violet-500/15 text-2xl">⚡</div>
                    <h3 class="font-display font-semibold text-white">Babar Baloch</h3>
                    <p class="mt-1 text-sm text-slate-500">Frontend developer</p>
                </div>
            </div>
        </div>
    </section>

    <section class="mx-auto max-w-4xl px-4 py-20">
        <div data-anim="reveal" class="relative overflow-hidden rounded-3xl border border-sky-500/20 bg-gradient-to-br from-sky-500/10 via-[rgba(17,25,40,0.9)] to-[#05070a] p-10 text-center sm:p-14">
            <div class="pointer-events-none absolute -right-20 -top-20 h-56 w-56 rounded-full bg-sky-400/20 blur-3xl"></div>
            <h2 class="relative font-display text-2xl font-bold text-white sm:text-3xl">Ready to explore?</h2>
            <p class="relative mx-auto mt-3 max-w-lg text-slate-400">Create a free account or jump back to the home page. Nothing here is financial advice.</p>
            <div class="relative mt-8 flex flex-wrap justify-center gap-3">
                <a asp-controller="Home" asp-action="Signup" class="inline-flex items-center justify-center rounded-xl bg-sky-400 px-8 py-3 font-display text-sm font-bold uppercase tracking-wide text-[#05070a] transition hover:bg-sky-300">Create account</a>
                <a asp-controller="Home" asp-action="Index" class="inline-flex items-center justify-center rounded-xl border border-white/20 bg-white/5 px-8 py-3 font-display text-sm font-semibold text-white transition hover:border-sky-500/40 hover:bg-white/10">Home</a>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>
    <script>
        gsap.registerPlugin(ScrollTrigger);
        gsap.from('[data-anim="hero-line"]', {
            opacity: 0,
            y: 28,
            duration: 0.85,
            stagger: 0.1,
            ease: 'power3.out',
        });
        gsap.utils.toArray('[data-anim="reveal"]').forEach(function (el) {
            gsap.from(el, {
                opacity: 0,
                y: 32,
                duration: 0.75,
                ease: 'power2.out',
                scrollTrigger: { trigger: el, start: 'top 90%', toggleActions: 'play none none none' },
            });
        });
    </script>
}
