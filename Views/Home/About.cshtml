@{
    ViewData["Title"] = "About Us";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2 text-center">
            <h1 class="display-4 text-primary mb-4">About Vest</h1>
            <p class="lead text-muted">
                Vest is a modern platform designed to streamline your investment tracking and portfolio management. 
                Our mission is to provide clear, actionable insights into your financial health.
            </p>
            <hr class="my-4">
            <div class="card border-0 p-4">
                <h3>Our Vision</h3>
                <p>
                    We believe in financial transparency and accessibility for everyone. Whether you're a seasoned investor 
                    or just starting out, Vest provides the tools you need to succeed.
                </p>
            </div>
            <div class="mt-5">
                <a href="/" class="btn btn-outline-primary btn-lg px-4">Get Started</a>
            </div>
        </div>
    </div>
</div>
