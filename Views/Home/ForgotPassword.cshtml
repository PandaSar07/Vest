@model Vest.Models.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
    bool success = TempData["ForgotSuccess"] != null;
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header text-center">
            <h1 class="auth-title">Forgot Password</h1>
            <p class="auth-subtitle">Enter your email and we'll send you a reset link.</p>
        </div>

        @if (!success)
        {
            <form asp-action="ForgotPassword" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"
                     style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                <div class="form-group mb-4">
                    <label asp-for="Email">Email Address</label>
                    <input asp-for="Email" class="form-control mt-1" placeholder="you@example.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="row g-2">
                    <div class="col-12 col-sm-6">
                        <button type="submit" class="btn btn-primary w-100">Send Reset Link</button>
                    </div>
                    <div class="col-12 col-sm-6">
                        <a asp-action="Log" class="btn btn-outline w-100">Back to Login</a>
                    </div>
                </div>
            </form>
        }
        else
        {
            <div class="reset-success-box">
                <div class="reset-success-icon">✓</div>
                <p class="reset-success-title">Check Your Email</p>
                <p class="reset-success-text">
                    If an account with that email exists, we've sent a password reset link.
                    The link expires in <strong>1 hour</strong>.
                </p>
                <p class="reset-success-text" style="font-size:0.8rem;">
                    Don't see it? Check your spam folder.
                </p>
            </div>

            <a asp-action="Log" class="btn btn-outline w-100">Back to Login</a>
        }
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
