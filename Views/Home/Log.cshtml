@model Vest.Models.LoginViewModel

@{
    ViewData["Title"] = "Log In";
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header text-center">
            <h1 class="auth-title">Welcome Back</h1>
            <p class="auth-subtitle">Sign in to access your portfolio.</p>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }

        <form asp-action="Log" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

            <div class="form-group mb-3">
                <label asp-for="Email">Email Address</label>
                <input asp-for="Email" class="form-control mt-1" placeholder="you@example.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="form-group mb-4">
                <div class="d-flex justify-content-between align-items-center">
                    <label asp-for="Password">Password</label>
                    <a asp-action="ForgotPassword" class="forgot-link">Forgot password?</a>
                </div>
                <input asp-for="Password" class="form-control mt-1" placeholder="Enter your password" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="row g-2">
                <div class="col-12 col-sm-6">
                    <button type="submit" class="btn btn-primary w-100">Log In</button>
                </div>
                <div class="col-12 col-sm-6">
                    <a asp-action="Signup" class="btn btn-outline w-100">Sign Up</a>
                </div>
            </div>

            <div class="mt-4 mb-3 position-relative text-center">
                <hr />
                <span class="position-absolute top-50 start-50 translate-middle px-3 text-muted small" style="background-color: var(--bs-body-bg);">OR</span>
            </div>

            <a asp-action="GoogleLogin" class="btn btn-light w-100 d-flex align-items-center justify-content-center gap-2" style="background-color: white; color: black; border-color: #ddd;">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-google" viewBox="0 0 16 16">
                  <path d="M15.545 6.558a9.4 9.4 0 0 1 .139 1.626c0 2.434-.87 4.492-2.384 5.885h.002C11.978 15.292 10.158 16 8 16A8 8 0 1 1 8 0a7.7 7.7 0 0 1 5.352 2.082l-2.284 2.284A4.35 4.35 0 0 0 8 3.166c-2.087 0-3.86 1.408-4.492 3.304a4.8 4.8 0 0 0 0 3.063h.003c.635 1.893 2.405 3.301 4.492 3.301 1.078 0 2.004-.276 2.722-.764h-.003a3.7 3.7 0 0 0 1.599-2.431H8v-3.08z"/>
                </svg>
                Continue with Google
            </a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}