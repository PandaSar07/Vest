@model Vest.Models.LoginViewModel

@{
    ViewData["Title"] = "Log In";
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header text-center">
            <h1 class="auth-title">Welcome Back</h1>
            <p class="auth-subtitle">Sign in to access your portfolio.</p>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }

        <form asp-action="Log" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

            <div class="form-group mb-3">
                <label asp-for="Email">Email Address</label>
                <input asp-for="Email" class="form-control mt-1" placeholder="you@example.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="form-group mb-4">
                <div class="d-flex justify-content-between align-items-center">
                    <label asp-for="Password">Password</label>
                    <a asp-action="ForgotPassword" class="forgot-link">Forgot password?</a>
                </div>
                <input asp-for="Password" class="form-control mt-1" placeholder="Enter your password" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="row g-2">
                <div class="col-6">
                    <button type="submit" class="btn btn-primary w-100">Sign In</button>
                </div>
                <div class="col-6">
                    <a asp-action="Signup" class="btn btn-outline w-100">Sign Up</a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}