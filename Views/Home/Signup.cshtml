@model Vest.Models.SignupViewModel

@{
    ViewData["Title"] = "Sign Up";
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header text-center">
            <h1 class="auth-title">Create Your Account</h1>
            <p class="auth-subtitle">Join Vest and start learning to invest smarter.</p>
        </div>

        <form asp-action="Signup" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

            <div class="form-group mb-3">
                <label asp-for="FullName">Full Name</label>
                <input asp-for="FullName" class="form-control mt-1" placeholder="John Doe" />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Email">Email Address</label>
                <input asp-for="Email" class="form-control mt-1" placeholder="you@example.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Username">Username</label>
                <input asp-for="Username" class="form-control mt-1" placeholder="Choose a username" />
                <span asp-validation-for="Username" class="text-danger small"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Password">Password</label>
                <input asp-for="Password" class="form-control mt-1" placeholder="At least 6 characters" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="ConfirmPassword">Confirm Password</label>
                <input asp-for="ConfirmPassword" class="form-control mt-1" placeholder="Repeat your password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <div class="row g-2">
                <div class="col-6">
                    <button type="submit" class="btn btn-primary w-100">Create Account</button>
                </div>
                <div class="col-6">
                    <a asp-action="Log" class="btn btn-outline w-100">Back to Login</a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}