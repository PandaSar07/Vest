@{
    ViewData["Title"] = "Stock Screener";
}

<style>
    /* ─── Page Layout ──────────────────────────────────────────────────────── */
    .screener-page { padding: 2rem 0 4rem; }

    /* ─── Highlights row ───────────────────────────────────────────────────── */
    .highlights-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
        margin-bottom: 2rem;
    }

    @@media (max-width: 900px) { .highlights-row { grid-template-columns: 1fr 1fr; } }
    @@media (max-width: 500px) { .highlights-row { grid-template-columns: 1fr; } }

    .hl-card {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: var(--radius-md);
        backdrop-filter: var(--glass-blur);
        padding: 1.1rem 1.2rem;
        position: relative;
        overflow: hidden;
        transition: var(--transition);
    }

    .hl-card::before {
        content: '';
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity 0.25s;
    }

    .hl-card.hl-gain  { border-color: rgba(16,185,129,0.3); }
    .hl-card.hl-gain::before  { background: radial-gradient(ellipse at top left, rgba(16,185,129,0.07), transparent 70%); }
    .hl-card.hl-loss  { border-color: rgba(239,68,68,0.3); }
    .hl-card.hl-loss::before  { background: radial-gradient(ellipse at top left, rgba(239,68,68,0.07), transparent 70%); }
    .hl-card.hl-vol   { border-color: rgba(245,158,11,0.3); }
    .hl-card.hl-vol::before   { background: radial-gradient(ellipse at top left, rgba(245,158,11,0.07), transparent 70%); }
    .hl-card.hl-move  { border-color: rgba(139,92,246,0.3); }
    .hl-card.hl-move::before  { background: radial-gradient(ellipse at top left, rgba(139,92,246,0.07), transparent 70%); }
    .hl-card::before { opacity: 1; }

    .hl-label { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 1px; color: var(--text-secondary); font-weight: 700; margin-bottom: 0.5rem; }
    .hl-sym   { font-size: 1.3rem; font-weight: 800; font-family: var(--font-brand); }
    .hl-gain .hl-sym  { color: #10b981; }
    .hl-loss .hl-sym  { color: #ef4444; }
    .hl-vol .hl-sym   { color: #f59e0b; }
    .hl-move .hl-sym  { color: #8b5cf6; }
    .hl-name  { font-size: 0.75rem; color: var(--text-secondary); margin-bottom: 0.35rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .hl-val   { font-size: 1rem; font-weight: 700; }
    .hl-sub   { font-size: 0.78rem; color: var(--text-secondary); }

    /* ─── Filter bar ───────────────────────────────────────────────────────── */
    .filter-bar {
        display: flex;
        gap: 0.6rem;
        flex-wrap: wrap;
        align-items: center;
        margin-bottom: 1.2rem;
        padding: 0.9rem 1.1rem;
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: var(--radius-md);
        backdrop-filter: var(--glass-blur);
    }

    .sector-pill {
        padding: 0.3rem 0.85rem;
        border: 1px solid var(--border-color);
        border-radius: 9999px;
        background: transparent;
        color: var(--text-secondary);
        font-size: 0.78rem;
        font-weight: 600;
        cursor: pointer;
        transition: var(--transition);
        white-space: nowrap;
    }

    .sector-pill.active, .sector-pill:hover {
        background: rgba(56,189,248,0.12);
        border-color: var(--accent-color);
        color: var(--accent-color);
    }

    .filter-right { display: flex; gap: 0.6rem; margin-left: auto; align-items: center; }

    .ctrl-input {
        background: rgba(17,25,40,0.85);
        border: 1px solid var(--border-color);
        color: var(--text-primary);
        border-radius: var(--radius-sm);
        padding: 0.35rem 0.8rem;
        font-size: 0.82rem;
        font-family: var(--font-family);
        transition: var(--transition);
    }

    .ctrl-input:focus { outline: none; border-color: var(--accent-color); }
    .ctrl-input::placeholder { color: var(--text-secondary); }

    /* ─── Stats banner ────────────────────────────────────────────────────── */
    .stats-banner {
        display: flex;
        gap: 1.2rem;
        margin-bottom: 1rem;
        font-size: 0.8rem;
        color: var(--text-secondary);
        flex-wrap: wrap;
    }

    .stats-banner .s-up   { color: #10b981; font-weight: 700; }
    .stats-banner .s-down { color: #ef4444; font-weight: 700; }

    /* ─── Screener grid ────────────────────────────────────────────────────── */
    .screener-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 0.85rem;
    }

    /* ─── Stock card ───────────────────────────────────────────────────────── */
    .stock-card {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: var(--radius-md);
        backdrop-filter: var(--glass-blur);
        padding: 1rem 1.1rem;
        cursor: pointer;
        transition: var(--transition);
        text-decoration: none;
        display: block;
        position: relative;
        overflow: hidden;
    }

    .stock-card:hover {
        border-color: var(--accent-color);
        transform: translateY(-3px);
        box-shadow: 0 10px 35px rgba(56,189,248,0.12);
    }

    .stock-card.card-up   { border-top: 2px solid rgba(16,185,129,0.5); }
    .stock-card.card-down { border-top: 2px solid rgba(239,68,68,0.45); }

    .card-header  { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2px; }
    .card-symbol  { font-size: 1rem; font-weight: 800; color: var(--text-primary); font-family: var(--font-brand); }
    .card-pct     { font-size: 0.82rem; font-weight: 700; padding: 2px 7px; border-radius: 5px; }
    .pct-up   { background: rgba(16,185,129,0.15);  color: #10b981; }
    .pct-down { background: rgba(239,68,68,0.13);   color: #ef4444; }
    .card-name    { font-size: 0.72rem; color: var(--text-secondary); margin-bottom: 0.65rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .card-price   { font-size: 1.35rem; font-weight: 800; font-variant-numeric: tabular-nums; margin-bottom: 0.1rem; }
    .card-change  { font-size: 0.78rem; color: var(--text-secondary); margin-bottom: 0.7rem; }

    /* Day range bar */
    .range-bar-wrap { margin-bottom: 0.5rem; }
    .range-labels   { display: flex; justify-content: space-between; font-size: 0.65rem; color: var(--text-secondary); margin-bottom: 2px; }
    .range-track    { height: 4px; background: rgba(255,255,255,0.07); border-radius: 9999px; position: relative; }
    .range-fill     { height: 100%; border-radius: 9999px; position: absolute; left: 0; }
    .range-dot      {
        width: 8px; height: 8px; border-radius: 50%;
        position: absolute; top: 50%; transform: translate(-50%, -50%);
        border: 2px solid #05070a;
    }

    /* Volatility chip */
    .card-footer  { display: flex; justify-content: space-between; align-items: center; margin-top: 0.55rem; }
    .card-sector  { font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.7px; color: var(--text-secondary); }
    .vol-chip     {
        font-size: 0.62rem; font-weight: 700;
        padding: 2px 6px; border-radius: 4px;
        background: rgba(245,158,11,0.12); color: #f59e0b;
    }
    .vol-chip.low { background: rgba(16,185,129,0.1); color: #6ee7b7; }

    /* Skeleton */
    .card-skeleton { animation: pulse 1.5s ease-in-out infinite; }
    .card-skeleton .sk { background: rgba(255,255,255,0.06); border-radius: 5px; margin-bottom: 6px; }

    @@keyframes pulse { 0%,100% { opacity:1; } 50% { opacity:0.5; } }

    /* View toggle */
    .view-toggle { display: flex; gap: 0.4rem; }
    .vt-btn {
        width: 30px; height: 30px; display: flex; align-items: center; justify-content: center;
        border: 1px solid var(--border-color); border-radius: 6px; background: transparent;
        color: var(--text-secondary); cursor: pointer; transition: var(--transition);
        font-size: 0.85rem;
    }
    .vt-btn.active { border-color: var(--accent-color); color: var(--accent-color); background: rgba(56,189,248,0.08); }

    /* Table view */
    .screener-table { width: 100%; border-collapse: collapse; }
    .screener-table th, .screener-table td { padding: 0.75rem 1rem; font-size: 0.85rem; border-bottom: 1px solid rgba(255,255,255,0.04); }
    .screener-table th { color: var(--text-secondary); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.8px; font-weight: 600; cursor: pointer; user-select: none; }
    .screener-table th:hover { color: var(--accent-color); }
    .screener-table tbody tr:hover td { background: rgba(255,255,255,0.02); }
    .tbl-wrap { background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: var(--radius-md); backdrop-filter: var(--glass-blur); overflow: hidden; }
</style>

<div class="container screener-page">
    <div class="d-flex align-items-baseline gap-3 mb-1">
        <h1 class="display-5 mb-0">Market Screener</h1>
        <span id="mktStatus" style="font-size:0.75rem;font-weight:700;padding:3px 10px;border-radius:9999px;">&mdash;</span>
    </div>
    <p class="text-secondary mb-4">Live quotes across 55 major stocks. All data refreshed on load.</p>

    <!-- Highlights row -->
    <div class="highlights-row" id="hlRow">
        <div class="hl-card hl-gain"><div class="hl-label">🚀 Top Gainer</div><div class="hl-sym" id="hl-g-sym">—</div><div class="hl-name" id="hl-g-name">Loading…</div><div class="hl-val" id="hl-g-val">—</div><div class="hl-sub" id="hl-g-price">—</div></div>
        <div class="hl-card hl-loss"><div class="hl-label">📉 Top Loser</div><div class="hl-sym" id="hl-l-sym">—</div><div class="hl-name" id="hl-l-name">Loading…</div><div class="hl-val" id="hl-l-val">—</div><div class="hl-sub" id="hl-l-price">—</div></div>
        <div class="hl-card hl-vol"><div class="hl-label">⚡ Most Volatile</div><div class="hl-sym" id="hl-v-sym">—</div><div class="hl-name" id="hl-v-name">Loading…</div><div class="hl-val" id="hl-v-val">—</div><div class="hl-sub" id="hl-v-price">—</div></div>
        <div class="hl-card hl-move"><div class="hl-label">💰 Biggest Move $</div><div class="hl-sym" id="hl-m-sym">—</div><div class="hl-name" id="hl-m-name">Loading…</div><div class="hl-val" id="hl-m-val">—</div><div class="hl-sub" id="hl-m-price">—</div></div>
    </div>

    <!-- Filter bar -->
    <div class="filter-bar" id="filterBar">
        <button class="sector-pill active" data-sector="All">All</button>
        <button class="sector-pill" data-sector="Technology">Technology</button>
        <button class="sector-pill" data-sector="Finance">Finance</button>
        <button class="sector-pill" data-sector="Healthcare">Healthcare</button>
        <button class="sector-pill" data-sector="Consumer">Consumer</button>
        <button class="sector-pill" data-sector="Energy">Energy</button>
        <button class="sector-pill" data-sector="Industrials">Industrials</button>
        <button class="sector-pill" data-sector="Communication">Communication</button>
        <div class="filter-right">
            <input type="text" class="ctrl-input" id="symbolSearch" placeholder="Search…" autocomplete="off" style="width:130px;" />
            <select class="ctrl-input" id="sortSelect">
                <option value="symbol">A–Z</option>
                <option value="price-desc">Price ▼</option>
                <option value="price-asc">Price ▲</option>
                <option value="change-desc">Gainers</option>
                <option value="change-asc">Losers</option>
                <option value="vol-desc">Volatility ▼</option>
            </select>
            <div class="view-toggle">
                <button class="vt-btn active" id="viewGrid" title="Grid view">⊞</button>
                <button class="vt-btn" id="viewTable" title="Table view">☰</button>
            </div>
        </div>
    </div>

    <!-- Live stats banner -->
    <div class="stats-banner" id="statsBanner"></div>

    <!-- Grid content -->
    <div id="screenerContent"></div>
</div>

@section Scripts {
<script>
    // ── Stock manifest ─────────────────────────────────────────────────────
    const STOCKS = [
        { symbol:'AAPL',  name:'Apple',                  sector:'Technology'    },
        { symbol:'MSFT',  name:'Microsoft',              sector:'Technology'    },
        { symbol:'NVDA',  name:'NVIDIA',                 sector:'Technology'    },
        { symbol:'GOOGL', name:'Alphabet',               sector:'Technology'    },
        { symbol:'META',  name:'Meta Platforms',         sector:'Technology'    },
        { symbol:'AMZN',  name:'Amazon',                 sector:'Technology'    },
        { symbol:'TSLA',  name:'Tesla',                  sector:'Technology'    },
        { symbol:'AMD',   name:'AMD',                    sector:'Technology'    },
        { symbol:'INTC',  name:'Intel',                  sector:'Technology'    },
        { symbol:'ORCL',  name:'Oracle',                 sector:'Technology'    },
        { symbol:'CRM',   name:'Salesforce',             sector:'Technology'    },
        { symbol:'ADBE',  name:'Adobe',                  sector:'Technology'    },
        { symbol:'JPM',   name:'JPMorgan Chase',         sector:'Finance'       },
        { symbol:'BAC',   name:'Bank of America',        sector:'Finance'       },
        { symbol:'GS',    name:'Goldman Sachs',          sector:'Finance'       },
        { symbol:'MS',    name:'Morgan Stanley',         sector:'Finance'       },
        { symbol:'V',     name:'Visa',                   sector:'Finance'       },
        { symbol:'MA',    name:'Mastercard',             sector:'Finance'       },
        { symbol:'BRK.B', name:'Berkshire Hathaway B',  sector:'Finance'       },
        { symbol:'AXP',   name:'American Express',       sector:'Finance'       },
        { symbol:'BLK',   name:'BlackRock',              sector:'Finance'       },
        { symbol:'JNJ',   name:'Johnson & Johnson',      sector:'Healthcare'    },
        { symbol:'UNH',   name:'UnitedHealth',           sector:'Healthcare'    },
        { symbol:'PFE',   name:'Pfizer',                 sector:'Healthcare'    },
        { symbol:'ABBV',  name:'AbbVie',                 sector:'Healthcare'    },
        { symbol:'MRK',   name:'Merck',                  sector:'Healthcare'    },
        { symbol:'TMO',   name:'Thermo Fisher',          sector:'Healthcare'    },
        { symbol:'LLY',   name:'Eli Lilly',              sector:'Healthcare'    },
        { symbol:'AMGN',  name:'Amgen',                  sector:'Healthcare'    },
        { symbol:'WMT',   name:'Walmart',                sector:'Consumer'      },
        { symbol:'PG',    name:'Procter & Gamble',       sector:'Consumer'      },
        { symbol:'HD',    name:'Home Depot',             sector:'Consumer'      },
        { symbol:'MCD',   name:"McDonald's",             sector:'Consumer'      },
        { symbol:'NKE',   name:'Nike',                   sector:'Consumer'      },
        { symbol:'SBUX',  name:'Starbucks',              sector:'Consumer'      },
        { symbol:'KO',    name:'Coca-Cola',              sector:'Consumer'      },
        { symbol:'PEP',   name:'PepsiCo',                sector:'Consumer'      },
        { symbol:'COST',  name:'Costco',                 sector:'Consumer'      },
        { symbol:'XOM',   name:'ExxonMobil',             sector:'Energy'        },
        { symbol:'CVX',   name:'Chevron',                sector:'Energy'        },
        { symbol:'COP',   name:'ConocoPhillips',         sector:'Energy'        },
        { symbol:'SLB',   name:'SLB',                    sector:'Energy'        },
        { symbol:'OXY',   name:'Occidental Petroleum',   sector:'Energy'        },
        { symbol:'CAT',   name:'Caterpillar',            sector:'Industrials'   },
        { symbol:'DE',    name:'Deere & Company',        sector:'Industrials'   },
        { symbol:'BA',    name:'Boeing',                 sector:'Industrials'   },
        { symbol:'RTX',   name:'RTX Corp',               sector:'Industrials'   },
        { symbol:'HON',   name:'Honeywell',              sector:'Industrials'   },
        { symbol:'LMT',   name:'Lockheed Martin',        sector:'Industrials'   },
        { symbol:'GE',    name:'GE Aerospace',           sector:'Industrials'   },
        { symbol:'NFLX',  name:'Netflix',                sector:'Communication' },
        { symbol:'DIS',   name:'Walt Disney',            sector:'Communication' },
        { symbol:'T',     name:'AT&T',                   sector:'Communication' },
        { symbol:'VZ',    name:'Verizon',                sector:'Communication' },
        { symbol:'CMCSA', name:'Comcast',                sector:'Communication' },
        { symbol:'SPOT',  name:'Spotify',                sector:'Communication' },
    ];

    // ── State ───────────────────────────────────────────────────────────────
    let liveData = {};   // symbol → { c, d, dp, h, l, o, pc, vol }
    let activeSector = 'All';
    let searchTerm   = '';
    let sortKey      = 'symbol';
    let viewMode     = 'grid';

    // ── Helpers ─────────────────────────────────────────────────────────────
    const $  = id => document.getElementById(id);
    const fp = (n, d=2) => n == null ? '—' : Number(n).toLocaleString('en-US',{minimumFractionDigits:d,maximumFractionDigits:d});

    // Daily range % of prev close = measure of intraday volatility
    function dayVol(d) {
        if (!d || !d.pc || d.pc === 0) return 0;
        return Math.abs((d.h - d.l) / d.pc * 100);
    }

    // Position of current price in the day's range (0–100%)
    function rangePct(d) {
        if (!d || d.h === d.l) return 50;
        return Math.max(0, Math.min(100, (d.c - d.l) / (d.h - d.l) * 100));
    }

    // ── Market hours badge ───────────────────────────────────────────────────
    function isMarketOpen() {
        const et  = new Date(new Date().toLocaleString('en-US', { timeZone: 'America/New_York' }));
        const day = et.getDay(), m = et.getHours() * 60 + et.getMinutes();
        return day >= 1 && day <= 5 && m >= 570 && m < 960;
    }
    (function updateMktBadge() {
        const el = $('mktStatus');
        if (!el) return;
        const open = isMarketOpen();
        el.textContent = open ? '🟢 Market Open' : '🔴 Market Closed';
        el.style.cssText = `font-size:.75rem;font-weight:700;padding:3px 10px;border-radius:9999px;
            background:${open ? 'rgba(16,185,129,.15)' : 'rgba(239,68,68,.12)'};
            color:${open ? '#10b981' : '#ef4444'};
            border:1px solid ${open ? 'rgba(16,185,129,.3)' : 'rgba(239,68,68,.25)'}`;
    })();

    // ── Skeletons ────────────────────────────────────────────────────────────
    function renderSkeletons() {
        const grid = document.createElement('div');
        grid.className = 'screener-grid';
        grid.innerHTML = Array(12).fill(0).map(() => `
            <div class="stock-card card-skeleton">
                <div class="sk" style="width:70px;height:18px;"></div>
                <div class="sk" style="width:130px;height:11px;margin-top:4px;"></div>
                <div class="sk" style="width:90px;height:26px;margin-top:12px;"></div>
                <div class="sk" style="height:4px;margin-top:14px;"></div>
            </div>`).join('');
        $('screenerContent').replaceChildren(grid);
    }
    renderSkeletons();

    // ── Fetch all quotes ─────────────────────────────────────────────────────
    async function fetchAllQuotes() {
        await Promise.all(STOCKS.map(async s => {
            try {
                const r = await fetch(`/market/fullquote?symbol=${s.symbol}`);
                if (!r.ok) return;
                const q = await r.json();
                // Only store if price is real
                if (q && q.c > 0) liveData[s.symbol] = { c: q.c, d: q.d, dp: q.dp, h: q.h, l: q.l, o: q.o, pc: q.pc };
            } catch { }
        }));
        updateHighlights();
        updateStatsBanner();
        renderContent();
    }

    // ── Highlights ───────────────────────────────────────────────────────────
    function updateHighlights() {
        const loaded = STOCKS.filter(s => liveData[s.symbol]);

        // Top gainer
        const g = [...loaded].sort((a,b) => (liveData[b.symbol].dp??-99)-(liveData[a.symbol].dp??-99))[0];
        if (g) {
            $('hl-g-sym').textContent   = g.symbol;
            $('hl-g-name').textContent  = g.name;
            $('hl-g-val').textContent   = `+${fp(liveData[g.symbol].dp)}%`;
            $('hl-g-price').textContent = `$${fp(liveData[g.symbol].c)} · +$${fp(liveData[g.symbol].d)}`;
        }

        // Top loser
        const l = [...loaded].sort((a,b) => (liveData[a.symbol].dp??99)-(liveData[b.symbol].dp??99))[0];
        if (l) {
            $('hl-l-sym').textContent   = l.symbol;
            $('hl-l-name').textContent  = l.name;
            $('hl-l-val').textContent   = `${fp(liveData[l.symbol].dp)}%`;
            $('hl-l-price').textContent = `$${fp(liveData[l.symbol].c)} · -$${fp(Math.abs(liveData[l.symbol].d))}`;
        }

        // Most volatile (biggest intraday range %)
        const v = [...loaded].sort((a,b) => dayVol(liveData[b.symbol])-dayVol(liveData[a.symbol]))[0];
        if (v) {
            const vd = liveData[v.symbol];
            $('hl-v-sym').textContent   = v.symbol;
            $('hl-v-name').textContent  = v.name;
            $('hl-v-val').textContent   = `${fp(dayVol(vd))}% daily range`;
            $('hl-v-price').textContent = `H: $${fp(vd.h)}  L: $${fp(vd.l)}`;
        }

        // Biggest $ move
        const m = [...loaded].sort((a,b) => Math.abs(liveData[b.symbol].d)-Math.abs(liveData[a.symbol].d))[0];
        if (m) {
            const md = liveData[m.symbol];
            $('hl-m-sym').textContent   = m.symbol;
            $('hl-m-name').textContent  = m.name;
            const sign = md.d >= 0 ? '+' : '';
            $('hl-m-val').textContent   = `${sign}$${fp(Math.abs(md.d))} per share`;
            $('hl-m-price').textContent = `$${fp(md.pc)} → $${fp(md.c)}`;
        }
    }

    // ── Stats banner ─────────────────────────────────────────────────────────
    function updateStatsBanner() {
        const loaded = STOCKS.filter(s => liveData[s.symbol]);
        const ups    = loaded.filter(s => liveData[s.symbol].dp >= 0).length;
        const downs  = loaded.length - ups;
        const avgVol = loaded.reduce((sum,s) => sum + dayVol(liveData[s.symbol]), 0) / (loaded.length || 1);
        $('statsBanner').innerHTML = `
            <span>Loaded <strong>${loaded.length}</strong> of ${STOCKS.length} stocks</span>
            <span>▲ <span class="s-up">${ups} advancing</span></span>
            <span>▼ <span class="s-down">${downs} declining</span></span>
            <span>Avg volatility: <strong>${fp(avgVol)}%</strong></span>`;
    }

    // ── Render helpers ───────────────────────────────────────────────────────
    function filteredSorted() {
        let list = STOCKS.filter(s => {
            const ok1 = activeSector === 'All' || s.sector === activeSector;
            const ok2 = !searchTerm || s.symbol.startsWith(searchTerm) || s.name.toUpperCase().includes(searchTerm);
            return ok1 && ok2;
        });
        list.sort((a,b) => {
            const da = liveData[a.symbol], db = liveData[b.symbol];
            if (sortKey === 'symbol')      return a.symbol.localeCompare(b.symbol);
            if (sortKey === 'price-desc')  return (db?.c??0)-(da?.c??0);
            if (sortKey === 'price-asc')   return (da?.c??0)-(db?.c??0);
            if (sortKey === 'change-desc') return (db?.dp??-99)-(da?.dp??-99);
            if (sortKey === 'change-asc')  return (da?.dp??99)-(db?.dp??99);
            if (sortKey === 'vol-desc')    return dayVol(db)-dayVol(da);
            return 0;
        });
        return list;
    }

    // ── Card HTML ─────────────────────────────────────────────────────────────
    function cardHTML(s) {
        const d = liveData[s.symbol];
        const noData = !d;
        const isUp   = !noData && d.dp >= 0;
        const priceStr  = noData ? '—' : `$${fp(d.c)}`;
        const pctStr    = noData ? '—' : `${isUp?'+':''}${fp(d.dp)}%`;
        const changeStr = noData ? '' : `${isUp?'+':'-'}$${fp(Math.abs(d.d))} (${isUp?'▲':'▼'} from $${fp(d.pc)})`;
        const vol       = dayVol(d);
        const rp        = rangePct(d);
        const volLabel  = vol < 1 ? 'Low Vol' : vol < 3 ? 'Moderate' : 'High Vol';
        const volClass  = vol < 1 ? 'low' : '';

        const rangeBar = noData ? '' : `
            <div class="range-bar-wrap">
                <div class="range-labels">
                    <span>L $${fp(d.l)}</span>
                    <span style="font-size:0.6rem;color:var(--text-secondary);">Day Range</span>
                    <span>H $${fp(d.h)}</span>
                </div>
                <div class="range-track">
                    <div class="range-fill" style="width:${rp}%;background:${isUp?'#10b981':'#ef4444'};opacity:0.35;"></div>
                    <div class="range-dot" style="left:${rp}%;background:${isUp?'#10b981':'#ef4444'};"></div>
                </div>
            </div>`;

        return `
        <a class="stock-card ${noData?'':isUp?'card-up':'card-down'}" href="/Stocks?symbol=${s.symbol}">
            <div class="card-header">
                <span class="card-symbol">${s.symbol}</span>
                ${noData ? '' : `<span class="card-pct ${isUp?'pct-up':'pct-down'}">${pctStr}</span>`}
            </div>
            <div class="card-name">${s.name}</div>
            <div class="card-price">${priceStr}</div>
            <div class="card-change">${changeStr}</div>
            ${rangeBar}
            <div class="card-footer">
                <span class="card-sector">${s.sector}</span>
                ${noData ? '' : `<span class="vol-chip ${volClass}">⚡ ${volLabel} ${fp(vol)}%</span>`}
            </div>
        </a>`;
    }

    // ── Table row HTML ────────────────────────────────────────────────────────
    function tableRowHTML(s) {
        const d = liveData[s.symbol];
        const isUp = d && d.dp >= 0;
        const clr  = !d ? '' : isUp ? 'color:#10b981' : 'color:#ef4444';
        const vol  = fp(dayVol(d));
        return `<tr>
            <td><a href="/Stocks?symbol=${s.symbol}" style="color:var(--accent-color);font-weight:800;text-decoration:none;">${s.symbol}</a></td>
            <td style="color:var(--text-secondary);font-size:0.82rem;">${s.name}</td>
            <td class="fw-bold">${d ? '$'+fp(d.c) : '—'}</td>
            <td style="${clr}">${d ? (isUp?'+':'')+fp(d.dp)+'%' : '—'}</td>
            <td style="${clr}">${d ? (isUp?'+':'-')+'$'+fp(Math.abs(d.d)) : '—'}</td>
            <td>$${d?fp(d.h):'—'}</td>
            <td>$${d?fp(d.l):'—'}</td>
            <td style="color:#f59e0b;">${d ? fp(dayVol(d))+'%' : '—'}</td>
            <td style="color:var(--text-secondary);font-size:0.75rem;">${s.sector}</td>
        </tr>`;
    }

    // ── Main render ───────────────────────────────────────────────────────────
    function renderContent() {
        const list = filteredSorted();
        const content = $('screenerContent');

        if (list.length === 0) {
            content.innerHTML = `<p style="color:var(--text-secondary);padding:2rem 0;">No stocks match your filters.</p>`;
            return;
        }

        if (viewMode === 'grid') {
            const wrap = document.createElement('div');
            wrap.className = 'screener-grid';
            wrap.innerHTML = list.map(cardHTML).join('');
            content.replaceChildren(wrap);
        } else {
            const wrap = document.createElement('div');
            wrap.className = 'tbl-wrap';
            wrap.innerHTML = `
                <table class="screener-table">
                    <thead><tr>
                        <th data-sort="symbol">Symbol</th>
                        <th>Name</th>
                        <th data-sort="price-desc">Price</th>
                        <th data-sort="change-desc">Change%</th>
                        <th data-sort="change-desc">Change $</th>
                        <th>Day High</th>
                        <th>Day Low</th>
                        <th data-sort="vol-desc">Volatility</th>
                        <th>Sector</th>
                    </tr></thead>
                    <tbody>${list.map(tableRowHTML).join('')}</tbody>
                </table>`;
            // Table header sort
            wrap.querySelectorAll('th[data-sort]').forEach(th => {
                th.style.cursor = 'pointer';
                th.addEventListener('click', () => { sortKey = th.dataset.sort; renderContent(); });
            });
            content.replaceChildren(wrap);
        }
    }

    // ── Event listeners ───────────────────────────────────────────────────────
    document.getElementById('filterBar').addEventListener('click', e => {
        const pill = e.target.closest('.sector-pill');
        if (!pill) return;
        document.querySelectorAll('.sector-pill').forEach(p => p.classList.remove('active'));
        pill.classList.add('active');
        activeSector = pill.dataset.sector;
        renderContent();
    });

    $('symbolSearch').addEventListener('input', e => {
        searchTerm = e.target.value.toUpperCase().trim();
        renderContent();
    });

    $('sortSelect').addEventListener('change', e => {
        sortKey = e.target.value;
        renderContent();
    });

    $('viewGrid').addEventListener('click', () => {
        viewMode = 'grid';
        $('viewGrid').classList.add('active');
        $('viewTable').classList.remove('active');
        renderContent();
    });

    $('viewTable').addEventListener('click', () => {
        viewMode = 'table';
        $('viewTable').classList.add('active');
        $('viewGrid').classList.remove('active');
        renderContent();
    });

    // ── Boot ──────────────────────────────────────────────────────────────────
    fetchAllQuotes();
</script>
}
