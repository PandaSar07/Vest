@{
    ViewData["Title"] = "Stocks";
}

<style>
    /* ── Page-level overrides ── */
    .stocks-hero {
        padding: 2.5rem 0 1.5rem;
    }

    .search-wrap {
        position: relative;
        max-width: 520px;
    }

    .search-wrap input {
        background: rgba(17, 25, 40, 0.8);
        border: 1px solid var(--border-color);
        color: var(--text-primary);
        border-radius: var(--radius-md);
        padding: 0.85rem 1.25rem;
        width: 100%;
        font-size: 1rem;
        font-family: var(--font-family);
        transition: var(--transition);
    }

    .search-wrap input:focus {
        outline: none;
        border-color: var(--accent-color);
        box-shadow: 0 0 0 3px var(--accent-glow);
        caret-color: var(--accent-color);
    }

    .search-wrap input::placeholder {
        color: var(--text-secondary);
    }

    .search-btn {
        position: absolute;
        right: 8px;
        top: 50%;
        transform: translateY(-50%);
        background: var(--accent-color);
        border: none;
        color: #0a0e1a;
        border-radius: 10px;
        padding: 0.5rem 1.25rem;
        font-weight: 700;
        font-size: 0.88rem;
        cursor: pointer;
        transition: var(--transition);
        letter-spacing: 0.5px;
    }

    .search-btn:hover {
        background: var(--accent-hover);
        box-shadow: 0 0 12px var(--accent-glow);
    }

    /* ── Profile header ── */
    .profile-header {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        flex-wrap: wrap;
        animation: fadeIn 0.5s ease-out;
    }

    .company-logo {
        width: 56px;
        height: 56px;
        border-radius: 12px;
        object-fit: contain;
        background: rgba(255,255,255,0.05);
        padding: 6px;
        border: 1px solid var(--border-color);
    }

    .company-name {
        font-family: var(--font-brand);
        font-size: 1.7rem;
        background: linear-gradient(135deg, #ffffff 0%, #94a3b8 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        margin: 0;
    }

    .company-meta {
        display: flex;
        gap: 0.6rem;
        flex-wrap: wrap;
        margin-top: 0.3rem;
    }

    .meta-pill {
        font-size: 0.75rem;
        padding: 3px 10px;
        border-radius: 9999px;
        background: rgba(56, 189, 248, 0.08);
        border: 1px solid rgba(56, 189, 248, 0.2);
        color: var(--accent-color);
        font-weight: 600;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    /* ── Watchlist button ── */
    .wl-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: transparent;
        border: 1px solid rgba(56, 189, 248, 0.3);
        color: var(--accent-color);
        border-radius: var(--radius-sm);
        padding: 0.45rem 1.1rem;
        font-size: 0.82rem;
        font-weight: 600;
        cursor: pointer;
        transition: var(--transition);
        letter-spacing: 0.4px;
        white-space: nowrap;
    }

    .wl-btn:hover {
        background: rgba(56, 189, 248, 0.1);
        border-color: var(--accent-color);
        box-shadow: 0 0 12px var(--accent-glow);
    }

    .wl-btn.active {
        background: rgba(56, 189, 248, 0.15);
        border-color: var(--accent-color);
        color: var(--accent-color);
    }

    .wl-btn.active:hover {
        background: rgba(239, 68, 68, 0.1);
        border-color: rgba(239, 68, 68, 0.6);
        color: #ef4444;
    }

    .wl-btn.active:hover .wl-btn-label::before { content: '✕ Remove'; }
    .wl-btn.active .wl-btn-label::before       { content: '✓ Watchlisted'; }
    .wl-btn:not(.active) .wl-btn-label::before { content: '★ Watchlist'; }

    /* ── Stats bar ── */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
        gap: 0.75rem;
        margin: 1.5rem 0;
    }

    .stat-box {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: var(--radius-sm);
        padding: 0.9rem 1rem;
        backdrop-filter: var(--glass-blur);
        transition: var(--transition);
    }

    .stat-box:hover {
        border-color: rgba(56,189,248,0.3);
    }

    .stat-label {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--text-secondary);
        margin-bottom: 0.3rem;
    }

    .stat-value {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--text-primary);
        font-variant-numeric: tabular-nums;
    }

    .price-main {
        font-size: 2.6rem;
        font-weight: 800;
        font-variant-numeric: tabular-nums;
        line-height: 1;
        color: var(--text-primary);
    }

    .price-change {
        font-size: 1.15rem;
        font-weight: 600;
        margin-left: 0.75rem;
    }

    .change-up { color: var(--success-color); }
    .change-down { color: var(--danger-color); }

    /* ── Chart card ── */
    .chart-card {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: var(--radius-md);
        backdrop-filter: var(--glass-blur);
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        animation: fadeIn 0.6s ease-out;
    }

    .chart-toolbar {
        display: flex;
        justify-content: space-between;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-bottom: 1.25rem;
    }

    .range-btns {
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
    }

    .range-btn {
        background: transparent;
        border: 1px solid var(--border-color);
        color: var(--text-secondary);
        border-radius: var(--radius-sm);
        padding: 0.35rem 0.85rem;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: var(--transition);
        letter-spacing: 0.5px;
    }

    .range-btn:hover,
    .range-btn.active {
        background: var(--accent-color);
        border-color: var(--accent-color);
        color: #0a0e1a;
    }

    #stockChart {
        width: 100% !important;
        height: 380px !important;
    }

    /* ── News section ── */
    .news-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1rem;
        margin-top: 0.5rem;
    }

    .news-card {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: var(--radius-md);
        padding: 1.1rem 1.25rem;
        transition: var(--transition);
        text-decoration: none;
        display: block;
        backdrop-filter: var(--glass-blur);
    }

    .news-card:hover {
        border-color: rgba(56,189,248,0.35);
        transform: translateY(-4px);
        box-shadow: 0 12px 30px -10px rgba(0,0,0,0.5);
    }

    .news-source {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--accent-color);
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    .news-headline {
        font-size: 0.9rem;
        color: var(--text-primary);
        font-weight: 500;
        line-height: 1.45;
        margin-bottom: 0.5rem;
    }

    .news-date {
        font-size: 0.72rem;
        color: var(--text-secondary);
    }

    /* ── Skeleton / Loading ── */
    .skeleton {
        background: linear-gradient(90deg, rgba(255,255,255,0.04) 25%, rgba(255,255,255,0.08) 50%, rgba(255,255,255,0.04) 75%);
        background-size: 200% 100%;
        animation: shimmer 1.4s infinite;
        border-radius: 8px;
    }

    @@keyframes shimmer {
        0% { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }

    #loadingOverlay {
        display: none;
        position: absolute;
        inset: 0;
        background: rgba(5,7,10,0.7);
        border-radius: var(--radius-md);
        z-index: 10;
        align-items: center;
        justify-content: center;
    }

    .spinner {
        width: 36px;
        height: 36px;
        border: 3px solid var(--border-color);
        border-top-color: var(--accent-color);
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    .chart-wrap { position: relative; }

    .section-header {
        font-size: 1.1rem;
        font-family: var(--font-brand);
        background: linear-gradient(135deg, #fff 0%, #94a3b8 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 1rem;
        letter-spacing: 0.5px;
    }

    .live-dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        background: var(--success-color);
        border-radius: 50%;
        margin-right: 6px;
        animation: pulse-dot 2s ease-in-out infinite;
    }

    @@keyframes pulse-dot {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(1.4); }
    }
    /* ── Trade panel ── */
    .trade-card {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: var(--radius-md);
        backdrop-filter: var(--glass-blur);
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        animation: fadeIn 0.5s ease-out;
    }

    .trade-tabs {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 1.25rem;
    }

    .trade-tab {
        flex: 1;
        padding: 0.6rem;
        border: 1px solid var(--border-color);
        border-radius: var(--radius-sm);
        background: transparent;
        color: var(--text-secondary);
        font-weight: 700;
        font-size: 0.9rem;
        cursor: pointer;
        transition: var(--transition);
        letter-spacing: 0.5px;
    }

    .trade-tab.buy.active  { background: rgba(16,185,129,0.15); border-color: #10b981; color: #10b981; }
    .trade-tab.sell.active { background: rgba(239,68,68,0.15);  border-color: #ef4444; color: #ef4444; }
    .trade-tab:not(.active):hover { border-color: rgba(255,255,255,0.2); color: var(--text-primary); }

    .trade-row {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .trade-info-row {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
        margin-bottom: 1rem;
    }

    .trade-info-item {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .trade-info-label {
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--text-secondary);
        font-weight: 600;
    }

    .trade-info-value {
        font-size: 1rem;
        font-weight: 700;
        color: var(--text-primary);
        font-variant-numeric: tabular-nums;
    }

    .trade-input {
        background: rgba(17,25,40,0.8);
        border: 1px solid var(--border-color);
        color: var(--text-primary);
        border-radius: var(--radius-sm);
        padding: 0.6rem 0.9rem;
        font-size: 1rem;
        font-family: var(--font-family);
        width: 130px;
        transition: var(--transition);
        font-variant-numeric: tabular-nums;
    }

    .trade-input:focus {
        outline: none;
        border-color: var(--accent-color);
        box-shadow: 0 0 0 2px var(--accent-glow);
    }

    .trade-submit {
        padding: 0.6rem 1.4rem;
        border: none;
        border-radius: var(--radius-sm);
        font-weight: 700;
        font-size: 0.9rem;
        cursor: pointer;
        transition: var(--transition);
        min-width: 90px;
    }

    .trade-submit.buy-btn  { background: #10b981; color: #0a0e1a; }
    .trade-submit.sell-btn { background: #ef4444; color: #fff; }
    .trade-submit:hover    { transform: scale(1.04); filter: brightness(1.1); }
    .trade-submit:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

    .trade-est {
        font-size: 0.8rem;
        color: var(--text-secondary);
        margin-top: 0.4rem;
    }

    .trade-login-prompt {
        text-align: center;
        padding: 1.25rem;
        color: var(--text-secondary);
        font-size: 0.9rem;
    }

    /* Toast */
    #tradeToast {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        background: rgba(17,25,40,0.97);
        border: 1px solid var(--glass-border);
        border-radius: var(--radius-md);
        padding: 1rem 1.4rem;
        color: var(--text-primary);
        font-size: 0.9rem;
        z-index: 9999;
        transform: translateY(120%);
        transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
        max-width: 360px;
        backdrop-filter: blur(12px);
        box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    }

    #tradeToast.show { transform: translateY(0); }
    #tradeToast.toast-ok   { border-left: 3px solid #10b981; }
    #tradeToast.toast-err  { border-left: 3px solid #ef4444; }

</style>

<div class="container stocks-hero">

    <!-- Search bar -->
    <div class="mb-4">
        <div class="search-wrap">
            <input type="text" id="symbolInput" placeholder="Search symbol — e.g. AAPL, MSFT, TSLA" value="AAPL" autocomplete="off" />
            <button class="search-btn" id="searchBtn">Search</button>
        </div>
    </div>

    <!-- Company profile header -->
    <div id="profileSection" class="mb-3" style="min-height:70px;">
        <div class="profile-header" id="profileHeader">
            <div class="skeleton" style="width:56px;height:56px;border-radius:12px;"></div>
            <div>
                <div class="skeleton" style="width:200px;height:28px;margin-bottom:8px;border-radius:6px;"></div>
                <div class="skeleton" style="width:120px;height:18px;border-radius:6px;"></div>
            </div>
        </div>
    </div>

    <!-- Live price + stats -->
    <div id="quoteSection" class="mb-2">
        <div class="d-flex align-items-baseline flex-wrap gap-2 mb-3">
            <span class="price-main" id="priceMain">—</span>
            <span class="price-change" id="priceChange">—</span>
        </div>
        <div class="stats-grid" id="statsGrid">
            <!-- JS filled -->
        </div>
    </div>

    <!-- Chart -->
    <div class="chart-card">
        <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
            <div>
                <span class="live-dot"></span>
                <span class="section-header" style="display:inline;">Price History</span>
            </div>
        </div>
        <div class="chart-toolbar">
            <div class="range-btns" id="rangeBtns">
                <button class="range-btn" data-range="5d" data-interval="1h">1W</button>
                <button class="range-btn active" data-range="1mo" data-interval="1d">1M</button>
                <button class="range-btn" data-range="3mo" data-interval="1d">3M</button>
                <button class="range-btn" data-range="6mo" data-interval="1d">6M</button>
                <button class="range-btn" data-range="1y" data-interval="1d">1Y</button>
            </div>
            <div class="range-btns" id="chartTypeBtns">
                <button class="range-btn active" data-chart-type="line">Line</button>
                <button class="range-btn" data-chart-type="candles">Candles</button>
            </div>
        </div>
        <div class="chart-wrap">
            <div id="loadingOverlay" style="display:flex;">
                <div class="spinner"></div>
            </div>
            <canvas id="stockChart"></canvas>
        </div>
    </div>

    <!-- Trade panel -->
    <div class="trade-card mb-4" id="tradePanel">
        <div id="tradeLoggedIn">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;">
                <p class="section-header mb-0">Trade</p>
                <span id="marketBadge" style="font-size:0.72rem;font-weight:700;padding:3px 10px;border-radius:9999px;letter-spacing:0.5px;">—</span>
            </div>
            <!-- Account info row -->
            <div class="trade-info-row">
                <div class="trade-info-item">
                    <span class="trade-info-label">Cash Available</span>
                    <span class="trade-info-value" id="tradeCash">—</span>
                </div>
                <div class="trade-info-item">
                    <span class="trade-info-label" id="positionLabel">Shares Owned</span>
                    <span class="trade-info-value" id="tradeShares">—</span>
                </div>
                <div class="trade-info-item">
                    <span class="trade-info-label">Avg Cost</span>
                    <span class="trade-info-value" id="tradeAvgCost">—</span>
                </div>
            </div>
            <!-- Buy / Sell / Limit tabs -->
            <div class="trade-tabs">
                <button class="trade-tab buy active" id="tabBuy"  onclick="switchTab('buy')">BUY</button>
                <button class="trade-tab sell"       id="tabSell" onclick="switchTab('sell')">SELL</button>
                <button class="trade-tab" style="border-color:rgba(251,191,36,0.4);color:#fbbf24;" id="tabLimit" onclick="switchTab('limit')">LIMIT</button>
            </div>
            <!-- Input row -->
            <div class="trade-row">
                <input type="number" class="trade-input" id="sharesInput" min="0.01" step="0.01" placeholder="Shares" value="1.00" />
                <input type="number" class="trade-input" id="limitPriceInput" min="0.01" step="0.01" placeholder="Limit $" style="display:none;" />
                <button class="trade-submit buy-btn" id="tradeSubmitBtn" onclick="submitTrade()">Buy</button>
            </div>
            <div class="trade-est" id="tradeEst">Est. cost: —</div>
        </div>
        <div id="tradeGuest" style="display:none;" class="trade-login-prompt">
            <a href="/Home/Log" style="color:var(--accent-color);font-weight:600;">Log in</a> to buy and sell stocks.
        </div>
    </div>

    <!-- News -->
    <div class="mb-5">
        <p class="section-header">Latest News</p>
        <div class="news-grid" id="newsGrid">
            <!-- JS filled -->
        </div>
    </div>

</div>

<!-- Toast -->
<div id="tradeToast"></div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <script>
        let chart;
        let currentSymbol = 'AAPL';
        let currentRange    = '1mo';
        let currentInterval = '1d';
        let currentChartType = 'line';
        let lastHistoryData = null;
        let lastHistorySymbol = 'AAPL';
        let refreshInterval;

        // ── Format helpers ──────────────────────────────────────────────
        const savedCurrency = localStorage.getItem('currencyDisplay') || 'USD';
        const currencySymbols = { 'USD': '$', 'EUR': '€', 'GBP': '£' };
        const currencySymbol = currencySymbols[savedCurrency] || '$';

        const fmt = (n, decimals = 2) => {
            if (n == null) return '—';
            let val = Number(n);
            if (savedCurrency === 'EUR') val *= 0.92;
            else if (savedCurrency === 'GBP') val *= 0.79;
            return val.toLocaleString('en-US', { minimumFractionDigits: decimals, maximumFractionDigits: decimals });
        };

        const fmtBig = n => {
            if (n == null) return '—';
            let val = Number(n);
            if (savedCurrency === 'EUR') val *= 0.92;
            else if (savedCurrency === 'GBP') val *= 0.79;
            
            if (val >= 1e12) return currencySymbol + (val / 1e12).toFixed(2) + 'T';
            if (val >= 1e9)  return currencySymbol + (val / 1e9).toFixed(2)  + 'B';
            if (val >= 1e6)  return currencySymbol + (val / 1e6).toFixed(2)  + 'M';
            return currencySymbol + val.toLocaleString();
        };

        const fmtDate = ts => new Date(ts * 1000).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
        const fmtTs   = ts => new Date(ts * 1000).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' });

        // ── Profile ─────────────────────────────────────────────────────
        async function loadProfile(symbol) {
            try {
                const r = await fetch(`/market/profile?symbol=${encodeURIComponent(symbol)}`);
                if (!r.ok) return;
                const p = await r.json();

                const el = document.getElementById('profileHeader');
                if (!p || !p.name) {
                    el.innerHTML = `<div><h1 class="company-name">${symbol.toUpperCase()}</h1></div>
                        <button class="wl-btn ms-auto" id="wlToggleBtn" onclick="toggleWatchlist('${symbol.toUpperCase()}')">
                          <span class="wl-btn-label"></span>
                        </button>`;
                    syncWlButtonFromServer(symbol.toUpperCase());
                    return;
                }

                const logo = p.logo
                    ? `<img src="${p.logo}" alt="${p.name}" class="company-logo" onerror="this.style.display='none'" />`
                    : '';
                const pills = [
                    p.exchange ? `<span class="meta-pill">${p.exchange}</span>` : '',
                    p.finnhubIndustry ? `<span class="meta-pill">${p.finnhubIndustry}</span>` : '',
                    p.currency ? `<span class="meta-pill">${p.currency}</span>` : '',
                    p.marketCapitalization ? `<span class="meta-pill">MCap ${fmtBig(p.marketCapitalization * 1e6)}</span>` : '',
                ].join('');

                el.innerHTML = `
                    ${logo}
                    <div>
                      <h1 class="company-name">${p.name} <span style="font-size:1rem;color:var(--text-secondary);font-family:var(--font-family);-webkit-text-fill-color:var(--text-secondary);">(${symbol.toUpperCase()})</span></h1>
                      <div class="company-meta">${pills}</div>
                    </div>
                    <button class="wl-btn ms-auto" id="wlToggleBtn" onclick="toggleWatchlist('${symbol.toUpperCase()}')">
                      <span class="wl-btn-label"></span>
                    </button>`;
                syncWlButtonFromServer(symbol.toUpperCase());
            } catch (e) {
                console.warn('Profile fetch error', e);
            }
        }

        // ── Quote ────────────────────────────────────────────────────────
        async function loadQuote(symbol) {
            try {
                const r = await fetch(`/market/fullquote?symbol=${encodeURIComponent(symbol)}`);
                if (!r.ok) return;
                const q = await r.json();

                // Current price
                const price = q.c;
                livePriceForTrade = price;   // keep trade panel in sync
                const change = q.d;
                const pct = q.dp;
                const isUp = change >= 0;

                document.getElementById('priceMain').textContent = currencySymbol + fmt(price);
                document.getElementById('priceChange').innerHTML =
                    `<span class="${isUp ? 'change-up' : 'change-down'}">
                        ${isUp ? '▲' : '▼'} ${fmt(Math.abs(change))} (${fmt(Math.abs(pct))}%)
                     </span>`;

                const stats = [
                    { label: 'Open',       value: currencySymbol + fmt(q.o) },
                    { label: 'Prev Close', value: currencySymbol + fmt(q.pc) },
                    { label: 'High',       value: currencySymbol + fmt(q.h) },
                    { label: 'Low',        value: currencySymbol + fmt(q.l) },
                    { label: 'Updated',    value: q.t ? fmtTs(q.t) : '—' },
                ];

                document.getElementById('statsGrid').innerHTML = stats.map(s => `
                    <div class="stat-box">
                        <div class="stat-label">${s.label}</div>
                        <div class="stat-value">${s.value}</div>
                    </div>`).join('');
            } catch (e) {
                console.warn('Quote fetch error', e);
            }
        }

        // ── History chart ─────────────────────────────────────────────────
        async function loadHistory(symbol, range, interval) {
            showSpinner(true);
            try {
                const r = await fetch(`/market/history?symbol=${encodeURIComponent(symbol)}&range=${range}&interval=${interval}`);
                if (!r.ok) throw new Error('Server error ' + r.status);
                const data = await r.json();
                lastHistoryData = data;
                lastHistorySymbol = symbol;

                if (!data || !data.timestamps || data.timestamps.length === 0) {
                    showNoData('No data available for this range.');
                    return;
                }

                renderChart(symbol, data, interval);
            } catch (e) {
                console.warn('History fetch error', e);
                showNoData('Failed to load price history.');
            } finally {
                showSpinner(false);
            }
        }

        function showSpinner(on) {
            document.getElementById('loadingOverlay').style.display = on ? 'flex' : 'none';
        }

        function showNoData(msg) {
            if (chart) { chart.destroy(); chart = null; }
            const canvas = document.getElementById('stockChart');
            canvas.style.height = '200px';
            const ctx = canvas.getContext('2d');
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = 'rgba(148,163,184,0.35)';
            ctx.font = '15px Inter, sans-serif';
            ctx.textAlign = 'center';
            ctx.fillText(msg || 'No data available.', canvas.width / 2, 100);
        }

        function buildHistoryPoints(data, interval) {
            const timestamps = Array.isArray(data?.timestamps) ? data.timestamps : [];
            const opens = Array.isArray(data?.opens) ? data.opens : [];
            const highs = Array.isArray(data?.highs) ? data.highs : [];
            const lows = Array.isArray(data?.lows) ? data.lows : [];
            const closes = Array.isArray(data?.closes) ? data.closes : [];

            return timestamps.map((ts, i) => {
                const close = closes[i];
                const open = opens[i] ?? close;
                const high = highs[i] ?? close;
                const low = lows[i] ?? close;
                if ([open, high, low, close].some(v => v == null)) return null;

                const d = new Date(ts * 1000);
                return {
                    ts,
                    label: interval === '1h'
                        ? d.toLocaleString('en-US', { month: 'short', day: 'numeric', hour: 'numeric' })
                        : d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }),
                    open: Number(open),
                    high: Number(high),
                    low: Number(low),
                    close: Number(close),
                };
            }).filter(point =>
                point &&
                [point.open, point.high, point.low, point.close].every(v => Number.isFinite(v))
            );
        }

        function createCandlestickPlugin(points) {
            return {
                id: 'vestCandles',
                afterDatasetsDraw(chartInstance) {
                    const { ctx, scales: { x, y } } = chartInstance;
                    if (!x || !y || !points.length) return;

                    const spacing = points.length > 1
                        ? Math.abs(x.getPixelForValue(1) - x.getPixelForValue(0))
                        : 14;
                    const bodyWidth = Math.max(4, Math.min(14, spacing * 0.58));

                    ctx.save();
                    ctx.lineWidth = 1.5;

                    points.forEach((point, index) => {
                        const xPos = x.getPixelForValue(index);
                        const openY = y.getPixelForValue(point.open);
                        const closeY = y.getPixelForValue(point.close);
                        const highY = y.getPixelForValue(point.high);
                        const lowY = y.getPixelForValue(point.low);
                        const rising = point.close >= point.open;
                        const color = rising ? '#10b981' : '#ef4444';
                        const top = Math.min(openY, closeY);
                        const bottom = Math.max(openY, closeY);
                        const bodyHeight = Math.max(2, bottom - top);

                        ctx.strokeStyle = color;
                        ctx.beginPath();
                        ctx.moveTo(xPos, highY);
                        ctx.lineTo(xPos, lowY);
                        ctx.stroke();

                        ctx.fillStyle = color;
                        ctx.fillRect(xPos - bodyWidth / 2, top, bodyWidth, bodyHeight);
                    });

                    ctx.restore();
                }
            };
        }

        function buildChartOptions(points, tooltipLabel) {
            return {
                responsive: true,
                maintainAspectRatio: false,
                interaction: { intersect: false, mode: 'index' },
                animation: { duration: 600, easing: 'easeInOutQuart' },
                scales: {
                    y: {
                        position: 'right',
                        beginAtZero: false,
                        grid: { color: 'rgba(255,255,255,0.04)' },
                        ticks: {
                            color: '#64748b',
                            font: { size: 11 },
                            callback: v => currencySymbol + v.toLocaleString()
                        },
                        border: { display: false }
                    },
                    x: {
                        grid: { display: false },
                        ticks: {
                            color: '#64748b',
                            font: { size: 11 },
                            maxTicksLimit: 8,
                            maxRotation: 0
                        },
                        border: { display: false }
                    }
                },
                plugins: {
                    legend: { display: false },
                    tooltip: tooltipLabel
                }
            };
        }

        function renderChart(symbol, data, interval) {
            const points = buildHistoryPoints(data, interval);
            if (!points.length) {
                showNoData('No data available for this range.');
                return;
            }

            if (chart) chart.destroy();

            const ctx = document.getElementById('stockChart').getContext('2d');
            const labels = points.map(point => point.label);
            const closes = points.map(point => point.close);
            const firstPrice = closes[0];
            const lastPrice = closes[closes.length - 1];
            const isUp = lastPrice >= firstPrice;
            const lineColor = isUp ? '#10b981' : '#ef4444';
            const fillColor = isUp ? 'rgba(16,185,129,0.12)' : 'rgba(239,68,68,0.12)';

            if (currentChartType === 'candles') {
                chart = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels,
                        datasets: [{
                            label: symbol.toUpperCase() + ' OHLC',
                            data: closes,
                            borderColor: 'rgba(0,0,0,0)',
                            backgroundColor: 'rgba(0,0,0,0)',
                            borderWidth: 0,
                            fill: false,
                            tension: 0,
                            pointRadius: 0,
                            pointHoverRadius: 0,
                            pointHitRadius: 12,
                        }]
                    },
                    options: buildChartOptions(points, {
                        backgroundColor: 'rgba(17,25,40,0.95)',
                        borderColor: 'rgba(56,189,248,0.2)',
                        borderWidth: 1,
                        titleColor: '#94a3b8',
                        bodyColor: '#ffffff',
                        bodyFont: { size: 13, weight: 'bold' },
                        padding: 12,
                        callbacks: {
                            label: context => {
                                const point = points[context.dataIndex];
                                return [
                                    ' Open  ' + currencySymbol + fmt(point.open),
                                    ' High  ' + currencySymbol + fmt(point.high),
                                    ' Low   ' + currencySymbol + fmt(point.low),
                                    ' Close ' + currencySymbol + fmt(point.close),
                                ];
                            }
                        }
                    }),
                    plugins: [createCandlestickPlugin(points)]
                });
                return;
            }

            chart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels,
                    datasets: [{
                        label: symbol.toUpperCase() + ' Close',
                        data: closes,
                        borderColor: lineColor,
                        backgroundColor: (context) => {
                            const gradient = context.chart.ctx.createLinearGradient(0, 0, 0, 380);
                            gradient.addColorStop(0, fillColor);
                            gradient.addColorStop(1, 'rgba(5,7,10,0)');
                            return gradient;
                        },
                        borderWidth: 2,
                        fill: true,
                        tension: 0.3,
                        pointRadius: 0,
                        pointHoverRadius: 5,
                        pointHoverBackgroundColor: lineColor,
                        pointHoverBorderColor: '#fff',
                        pointHoverBorderWidth: 2,
                    }]
                },
                options: buildChartOptions(points, {
                    backgroundColor: 'rgba(17,25,40,0.95)',
                    borderColor: 'rgba(56,189,248,0.2)',
                    borderWidth: 1,
                    titleColor: '#94a3b8',
                    bodyColor: '#ffffff',
                    bodyFont: { size: 14, weight: 'bold' },
                    padding: 12,
                    callbacks: {
                        label: ctx => ' ' + currencySymbol + fmt(ctx.parsed.y)
                    }
                })
            });
        }

        // ── News ─────────────────────────────────────────────────────────
        async function loadNews(symbol) {
            const grid = document.getElementById('newsGrid');
            grid.innerHTML = Array(4).fill(0).map(() =>
                `<div class="news-card">
                    <div class="skeleton" style="height:12px;width:70px;margin-bottom:8px;"></div>
                    <div class="skeleton" style="height:16px;margin-bottom:6px;"></div>
                    <div class="skeleton" style="height:16px;width:80%;"></div>
                 </div>`).join('');

            try {
                const r = await fetch(`/market/news?symbol=${encodeURIComponent(symbol)}`);
                if (!r.ok) throw new Error();
                const items = await r.json();
                const top = Array.isArray(items) ? items.slice(0, 6) : [];

                if (top.length === 0) {
                    grid.innerHTML = `<p style="color:var(--text-secondary);font-size:0.9rem;">No recent news found.</p>`;
                    return;
                }

                grid.innerHTML = top.map(n => `
                    <a class="news-card" href="${n.url}" target="_blank" rel="noopener">
                        <div class="news-source">${n.source || 'News'}</div>
                        <div class="news-headline">${n.headline || ''}</div>
                        <div class="news-date">${n.datetime ? fmtDate(n.datetime) : ''}</div>
                    </a>`).join('');
            } catch (e) {
                grid.innerHTML = `<p style="color:var(--text-secondary);font-size:0.9rem;">Could not load news.</p>`;
            }
        }

        // ── Market hours ───────────────────────────────────────────────────
        function isMarketOpen() {
            const now  = new Date();
            const et   = new Date(now.toLocaleString('en-US', { timeZone: 'America/New_York' }));
            const day  = et.getDay();   // 0=Sun,6=Sat
            const h    = et.getHours();
            const m    = et.getMinutes();
            const mins = h * 60 + m;
            return day >= 1 && day <= 5 && mins >= 570 && mins < 960; // 9:30–16:00 ET
        }

        function updateMarketBadge() {
            const el = document.getElementById('marketBadge');
            if (!el) return;
            const open = isMarketOpen();
            el.textContent = open ? '🟢 Market Open' : '🔴 Market Closed';
            el.style.background = open ? 'rgba(16,185,129,0.15)' : 'rgba(239,68,68,0.12)';
            el.style.color      = open ? '#10b981' : '#ef4444';
            el.style.border     = `1px solid ${open ? 'rgba(16,185,129,0.3)' : 'rgba(239,68,68,0.25)'}`;

            const submitBtn = document.getElementById('tradeSubmitBtn');
            const isLimitActive = document.getElementById('tabLimit')?.classList.contains('active');
            if (submitBtn && !isLimitActive) {
                submitBtn.disabled = !open;
                if (!open) submitBtn.title = 'Market orders are disabled while the market is closed.';
                else submitBtn.removeAttribute('title');
            }
        }

        updateMarketBadge();
        setInterval(updateMarketBadge, 60000);

        // ── Watchlist helpers (server-aware) ───────────────────────────────
        let wlSymbols = [];

        function syncWlButton(symbol) {
            const btn = document.getElementById('wlToggleBtn');
            if (!btn) return;
            const inList = wlSymbols.includes(symbol);
            btn.classList.toggle('active', inList);
        }

        async function toggleWatchlist(symbol) {
            const inList = wlSymbols.includes(symbol);
            try {
                const method = inList ? 'DELETE' : 'POST';
                const url    = inList ? `/api/watchlist/${encodeURIComponent(symbol)}` : '/api/watchlist';
                const r = await fetch(url, {
                    method,
                    headers: inList ? {} : { 'Content-Type': 'application/json' },
                    body:    inList ? undefined : JSON.stringify({ symbol })
                });
                if (r.status === 401) {
                    window.location.href = '/Home/Log';
                    return;
                }
                if (!r.ok) throw new Error('api');
                wlSymbols = inList ? wlSymbols.filter(s => s !== symbol) : [...wlSymbols, symbol];
                syncWlButton(symbol);
                const badge = document.getElementById('wlNavBadge');
                if (badge) { badge.textContent = wlSymbols.length; badge.style.display = wlSymbols.length > 0 ? 'inline' : 'none'; }
                return;
            } catch {
                alert('Could not update watchlist right now. Please try again.');
            }
        }

        async function syncWlButtonFromServer(symbol) {
            try {
                const r = await fetch('/api/watchlist');
                if (r.ok) {
                    const list = await r.json();
                    const btn  = document.getElementById('wlToggleBtn');
                    if (btn) btn.classList.toggle('active', list.includes(symbol));
                    wlSymbols = list;
                    return;
                }
            } catch { }
            syncWlButton(symbol);
        }

        // ── Trade panel ───────────────────────────────────────────────────
        let tradeMode = 'buy';
        let livePriceForTrade = 0;
        let userLoggedIn = false;

        async function loadHolding(symbol) {
            try {
                const r = await fetch(`/portfolio/holding?symbol=${encodeURIComponent(symbol)}`);
                if (r.status === 401) {
                    // Not logged in — show guest prompt
                    document.getElementById('tradeLoggedIn').style.display = 'none';
                    document.getElementById('tradeGuest').style.display = 'block';
                    userLoggedIn = false;
                    return;
                }
                document.getElementById('tradeLoggedIn').style.display = 'block';
                document.getElementById('tradeGuest').style.display = 'none';
                userLoggedIn = true;

                if (!r.ok) return;
                const d = await r.json();
                document.getElementById('tradeCash').textContent    = currencySymbol + fmt(d.cash);
                document.getElementById('tradeShares').textContent  = fmt(d.shares, 4);
                document.getElementById('tradeAvgCost').textContent = d.avgCost > 0 ? currencySymbol + fmt(d.avgCost) : '—';
            } catch(e) { console.warn('loadHolding error', e); }
        }

        function switchTab(mode) {
            tradeMode = mode;
            const isLimit = mode === 'limit';
            const isBuy   = mode === 'buy';
            document.getElementById('tabBuy').classList.toggle('active', isBuy);
            document.getElementById('tabSell').classList.toggle('active', mode === 'sell');
            document.getElementById('tabLimit').classList.toggle('active', isLimit);
            const btn = document.getElementById('tradeSubmitBtn');
            if (isLimit) {
                btn.textContent = 'Place Limit Order';
                btn.className   = 'trade-submit';
                btn.disabled = false;
                btn.style.background = 'linear-gradient(135deg,#f59e0b,#d97706)';
                document.getElementById('limitPriceInput').style.display = 'block';
            } else {
                document.getElementById('limitPriceInput').style.display = 'none';
                btn.style.background = '';
                btn.textContent = isBuy ? 'Buy' : 'Sell';
                btn.className   = 'trade-submit ' + (isBuy ? 'buy-btn' : 'sell-btn');
                btn.disabled = !isMarketOpen();
            }
            updateEst();
        }

        function updateEst() {
            const shares = parseFloat(document.getElementById('sharesInput').value) || 0;
            const cost = shares * livePriceForTrade;
            const label = tradeMode === 'buy' ? 'Est. cost' : 'Est. proceeds';
            document.getElementById('tradeEst').textContent =
                livePriceForTrade > 0
                    ? `${label}: ${currencySymbol}${fmt(cost)} @@ ${currencySymbol}${fmt(livePriceForTrade)}/share`
                    : `${label}: —`;
        }

        document.getElementById('sharesInput').addEventListener('input', updateEst);

        async function submitTrade() {
            const shares = parseFloat(document.getElementById('sharesInput').value);
            if (!shares || shares <= 0) { showToast('Enter a valid number of shares.', false); return; }
            if (Math.round(shares * 100) !== shares * 100) {
                showToast('Shares must be in increments of 0.01.', false);
                return;
            }

            // LIMIT order path
            if (tradeMode === 'limit') {
                const limitPrice = parseFloat(document.getElementById('limitPriceInput').value);
                if (!limitPrice || limitPrice <= 0) { showToast('Enter a valid limit price.', false); return; }
                const action = livePriceForTrade > 0 && limitPrice < livePriceForTrade ? 'BUY' : 'SELL';
                const r = await fetch('/portfolio/order', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ symbol: currentSymbol, shares, limitPrice, action })
                });
                const data = await r.json();
                showToast(r.ok ? data.message : (data.error || 'Failed.'), r.ok);
                return;
            }

            if (!isMarketOpen()) {
                showToast('Market is closed. Buy/Sell is available 9:30 AM - 4:00 PM ET.', false);
                updateMarketBadge();
                return;
            }

            const btn = document.getElementById('tradeSubmitBtn');
            btn.disabled = true;
            const endpoint = tradeMode === 'buy' ? '/portfolio/buy' : '/portfolio/sell';
            try {
                const r = await fetch(endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ symbol: currentSymbol, shares })
                });
                const data = await r.json();
                if (!r.ok) {
                    showToast(data.error || 'Trade failed.', false);
                } else {
                    showToast(data.message, true);
                    // Refresh panel with new balance
                    await loadHolding(currentSymbol);
                }
            } catch(e) {
                showToast('Network error. Please try again.', false);
            } finally {
                btn.disabled = false;
            }
        }

        let _toastTimer;
        function showToast(msg, ok) {
            const el = document.getElementById('tradeToast');
            el.textContent = msg;
            el.className = 'show ' + (ok ? 'toast-ok' : 'toast-err');
            clearTimeout(_toastTimer);
            _toastTimer = setTimeout(() => { el.className = ''; }, 3500);
        }

        // ── Master load ───────────────────────────────────────────────────
        async function loadAll(symbol) {
            currentSymbol = symbol.toUpperCase();
            clearInterval(refreshInterval);

            await Promise.all([
                loadProfile(currentSymbol),
                loadQuote(currentSymbol),
                loadHistory(currentSymbol, currentRange, currentInterval),
                loadNews(currentSymbol),
                loadHolding(currentSymbol),
            ]);

            // Refresh quote every 30 s and update trade estimate
            refreshInterval = setInterval(async () => {
                await loadQuote(currentSymbol);
                updateEst();
            }, 30000);
        }

        // ── Range buttons ─────────────────────────────────────────────────
        document.getElementById('rangeBtns').addEventListener('click', e => {
            const btn = e.target.closest('.range-btn');
            if (!btn) return;
            document.querySelectorAll('#rangeBtns .range-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            currentRange    = btn.dataset.range;
            currentInterval = btn.dataset.interval;
            loadHistory(currentSymbol, currentRange, currentInterval);
        });

        document.getElementById('chartTypeBtns').addEventListener('click', e => {
            const btn = e.target.closest('.range-btn');
            if (!btn) return;
            document.querySelectorAll('#chartTypeBtns .range-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            currentChartType = btn.dataset.chartType || 'line';
            if (lastHistoryData) {
                renderChart(lastHistorySymbol, lastHistoryData, currentInterval);
            }
        });

        // ── Search ────────────────────────────────────────────────────────
        document.getElementById('searchBtn').addEventListener('click', () => {
            const sym = document.getElementById('symbolInput').value.trim();
            if (sym) loadAll(sym);
        });

        document.getElementById('symbolInput').addEventListener('keydown', e => {
            if (e.key === 'Enter') {
                const sym = e.target.value.trim();
                if (sym) loadAll(sym);
            }
        });

        // ── Init ─────────────────────────────────────────────────────────
        const initSymbol = new URLSearchParams(window.location.search).get('symbol') || 'AAPL';
        document.getElementById('symbolInput').value = initSymbol;
        loadAll(initSymbol);
    </script>
}
