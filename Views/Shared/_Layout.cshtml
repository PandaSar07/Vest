                            <li class="nav-item">
                                <a class="nav-link @(navCtrl == "Home" && navAct == "Log" ? "active" : null)" asp-area="" asp-controller="Home" asp-action="Log">Log in</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(navCtrl == "Home" && navAct == "Signup" ? "active" : null)" asp-area="" asp-controller="Home" asp-action="Signup">Sign up</a>
