        </nav>
    </header>
    <div class="@(fluidMain ? "container-fluid" : "container") flex-grow-1">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="container">
            <div class="row align-items-center gy-2">
                <div class="col-md-6 text-center text-md-start">
                    <p class="mb-0">&copy; 2026 - <span class="text-gradient fw-bold">Vest</span>. All rights reserved.</p>
                    <p class="mb-0 mt-1 small text-secondary" style="opacity:0.85;">For educational use only. Not financial advice.</p>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <a class="footer-link me-3" asp-area="" asp-controller="Home" asp-action="About">About</a>
                    <a class="footer-link me-3" asp-area="" asp-controller="Home" asp-action="Contact">Contact</a>
                    <a class="footer-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Update watchlist badge — prefer server data when logged in
        (async function () {
            const badge = document.getElementById('wlNavBadge');
            if (!badge) return;
            try {
                const r = await fetch('/api/watchlist');
                if (r.ok) {
                    const list = await r.json();
                    if (list.length > 0) { badge.textContent = list.length; badge.style.display = 'inline'; }
                    return;
                }
            } catch { }
        })();

        // SaaS nav symbol search dropdown
        (function () {
            const form = document.getElementById('navSymbolForm');
            const input = document.getElementById('navSymbolInput');
            const dropdown = document.getElementById('navSymbolDropdown');
            if (!form || !input || !dropdown) return;

            const symbols = [
                { symbol: 'AAPL', name: 'Apple' },
                { symbol: 'MSFT', name: 'Microsoft' },
                { symbol: 'NVDA', name: 'NVIDIA' },
                { symbol: 'TSLA', name: 'Tesla' },
                { symbol: 'AMZN', name: 'Amazon' },
                { symbol: 'META', name: 'Meta' },
                { symbol: 'GOOGL', name: 'Alphabet' },
                { symbol: 'SPY', name: 'S&P 500 ETF' },
                { symbol: 'QQQ', name: 'Nasdaq 100 ETF' },
                { symbol: 'BTC-USD', name: 'Bitcoin' },
                { symbol: 'ETH-USD', name: 'Ethereum' },
                { symbol: 'SOL-USD', name: 'Solana' }
            ];

            let activeIndex = -1;
            let currentItems = [];
            let debounceTimer = null;
            let pendingReq = null;

            const closeDropdown = () => {
                dropdown.classList.remove('show');
                dropdown.innerHTML = '';
                activeIndex = -1;
                currentItems = [];
            };

            const renderDropdown = (items) => {
                if (!items.length) { closeDropdown(); return; }
                currentItems = items;
                dropdown.innerHTML = items.map((item, idx) => `
                    <button type="button" class="nav-search-item ${idx === activeIndex ? 'active' : ''}" data-symbol="${item.symbol}">
                        <span class="nav-search-symbol">${item.symbol}</span>
                        <span class="nav-search-name">${item.name}${item.price ? ` · $${Number(item.price).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}` : ''}</span>
                    </button>
                `).join('');
                dropdown.classList.add('show');
            };

            const fallbackSymbols = (q) => {
                const query = q.trim().toUpperCase();
                if (!query) return symbols.slice(0, 8);
                return symbols
                    .filter(s => s.symbol.includes(query) || s.name.toUpperCase().includes(query))
                    .slice(0, 8);
            };

            const querySymbols = async (q) => {
                const query = q.trim();
                if (!query) return fallbackSymbols('');

                try {
                    if (pendingReq) pendingReq.abort();
                    pendingReq = new AbortController();

                    const r = await fetch(`/market/searchsymbols?q=${encodeURIComponent(query)}`, {
                        signal: pendingReq.signal
                    });
                    if (!r.ok) throw new Error('Search failed');
                    const data = await r.json();
                    const list = Array.isArray(data.result) ? data.result : [];
                    const mapped = list.map(x => ({
                        symbol: (x.symbol || '').toUpperCase(),
                        name: x.description || x.type || '',
                        price: x.price
                    })).filter(x => x.symbol);

                    return mapped.length ? mapped.slice(0, 10) : fallbackSymbols(query);
                } catch {
                    return fallbackSymbols(query);
                } finally {
                    pendingReq = null;
                }
            };

            input.addEventListener('input', async () => {
                activeIndex = -1;
                if (debounceTimer) clearTimeout(debounceTimer);
                debounceTimer = setTimeout(async () => {
                    renderDropdown(await querySymbols(input.value));
                }, 120);
            });

            input.addEventListener('focus', async () => renderDropdown(await querySymbols(input.value)));

            dropdown.addEventListener('click', (e) => {
                const btn = e.target.closest('.nav-search-item');
                if (!btn) return;
                input.value = btn.getAttribute('data-symbol') || '';
                form.action = input.value.toUpperCase().includes('-USD') ? '/Crypto/Index' : '/Stocks/Index';
                form.submit();
            });

            input.addEventListener('keydown', (e) => {
                if (!currentItems.length) return;
                if (e.key === 'ArrowDown') {
                    e.preventDefault();
                    activeIndex = (activeIndex + 1) % currentItems.length;
                    renderDropdown(currentItems);
                    return;
                }
                if (e.key === 'ArrowUp') {
                    e.preventDefault();
                    activeIndex = (activeIndex - 1 + currentItems.length) % currentItems.length;
                    renderDropdown(currentItems);
                    return;
                }
                if (e.key === 'Enter' && activeIndex >= 0) {
                    e.preventDefault();
                    input.value = currentItems[activeIndex].symbol;
                    form.action = input.value.toUpperCase().includes('-USD') ? '/Crypto/Index' : '/Stocks/Index';
                    form.submit();
                }
                if (e.key === 'Escape') closeDropdown();
            });

            form.addEventListener('submit', () => {
                const sym = (input.value || '').trim().toUpperCase();
                form.action = sym.includes('-USD') ? '/Crypto/Index' : '/Stocks/Index';
            });

            document.addEventListener('click', (e) => {
                if (!form.contains(e.target)) closeDropdown();
            });
        })();
    </script>
