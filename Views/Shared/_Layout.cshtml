    <script>
        // ── Toggle open/close ──
        const fab      = document.getElementById('vest-ai-fab');
        const chatPanel = document.getElementById('vest-ai-chat');
        const closeBtn = document.getElementById('vest-ai-close');
        const chatInput = document.getElementById('vest-chat-input');

        fab.addEventListener('click', () => {
            const isOpen = chatPanel.classList.contains('vest-open');
            if (isOpen) {
                chatPanel.style.opacity = '0';
                chatPanel.style.transform = 'translateY(12px) scale(0.97)';
                setTimeout(() => { chatPanel.classList.remove('vest-open'); }, 180);
            } else {
                // Reposition chat panel relative to FAB if FAB was moved and chat wasn't
                if (fab.dataset.dragged === 'true' && chatPanel.dataset.dragged !== 'true') {
                    const rect = fab.getBoundingClientRect();
                    const chatWidth = 370;
                    const vh = window.innerHeight;
                    const vw = window.innerWidth;
                    
                    chatPanel.style.right = 'auto';
                    chatPanel.style.bottom = 'auto';
                    
                    // Preferably align right edge of chat with right edge of FAB
                    let left = rect.left + rect.width - chatWidth;
                    let top = rect.top - 570; // 560 max height + 10 margin
                    
                    // Stay within viewport
                    if (left < 10) left = 10;
                    if (left + chatWidth > vw - 10) left = vw - chatWidth - 10;
                    if (top < 10) top = 10;
                    if (top + 560 > vh - 10) top = vh - 560 - 10;

                    chatPanel.style.left = left + 'px';
                    chatPanel.style.top = top + 'px';
                }

                chatPanel.classList.add('vest-open');
                requestAnimationFrame(() => {
                    chatPanel.style.opacity = '1';
                    chatPanel.style.transform = 'translateY(0) scale(1)';
                });
                chatInput.focus();
            }
        });

        closeBtn.addEventListener('click', () => {
            chatPanel.style.opacity = '0';
            chatPanel.style.transform = 'translateY(12px) scale(0.97)';
            setTimeout(() => { chatPanel.classList.remove('vest-open'); }, 180);
        });

        // ── Unified Draggable Logic ──
        (function () {
            function makeDraggable(el, handle, options = {}) {
                let dragging = false;
                let startX, startY, origX, origY;
                let hasMoved = false;

                const start = (e) => {
                    if (e.target.closest('#vest-ai-close')) return;
                    
                    const clientX = e.type === 'touchstart' ? e.touches[0].clientX : e.clientX;
                    const clientY = e.type === 'touchstart' ? e.touches[0].clientY : e.clientY;

                    dragging = true;
                    hasMoved = false;
                    startX = clientX;
                    startY = clientY;

                    const rect = el.getBoundingClientRect();
                    origX = rect.left;
                    origY = rect.top;

                    el.style.transition = 'none';
                    el.style.right = 'auto';
                    el.style.bottom = 'auto';
                    el.style.left = origX + 'px';
                    el.style.top = origY + 'px';
                    
                    document.body.style.userSelect = 'none';
                    document.body.style.touchAction = 'none';
                };

                const move = (e) => {
                    if (!dragging) return;
                    
                    const clientX = e.type === 'touchmove' ? e.touches[0].clientX : e.clientX;
                    const clientY = e.type === 'touchmove' ? e.touches[0].clientY : e.clientY;

                    const dx = clientX - startX;
                    const dy = clientY - startY;

                    if (Math.abs(dx) > 5 || Math.abs(dy) > 5) {
                        hasMoved = true;
                    }

                    if (hasMoved) {
                        el.style.left = (origX + dx) + 'px';
                        el.style.top = (origY + dy) + 'px';
                        if (options.onDrag) options.onDrag(el, origX + dx, origY + dy);
                    }
                };

                const stop = () => {
                    if (!dragging) return;
                    dragging = false;
                    el.style.transition = '';
                    document.body.style.userSelect = '';
                    document.body.style.touchAction = '';
                    if (options.onStop) options.onStop(hasMoved);
                };

                handle.addEventListener('mousedown', start);
                handle.addEventListener('touchstart', start, { passive: false });
                document.addEventListener('mousemove', move);
                document.addEventListener('touchmove', move, { passive: false });
                document.addEventListener('mouseup', stop);
                document.addEventListener('touchend', stop);

                return {
                    wasDragged: () => hasMoved
                };
            }

            // Drag for Chat Panel
            const chatHandle = document.getElementById('vest-drag-handle');
            makeDraggable(chatPanel, chatHandle, {
                onStop: (moved) => {
                    if (moved) chatPanel.dataset.dragged = 'true';
                }
            });

            // FAB remains fixed; only the chat panel is draggable.
        })();

        // ── Suggested question click ──
        function vestAskSuggestion(btn) {
            const text = btn.querySelector('span:last-child').textContent.trim();
            chatInput.value = text;
            chatInput.focus();
            vestSendMessage();
        }

        // ── Send message ──
        function vestSendMessage() {
            const text = chatInput.value.trim();
            if (!text) return;
            chatInput.value = '';

            const body = document.getElementById('vest-chat-messages');

            // Hide welcome + suggestions on first message
            const welcome = document.getElementById('vest-welcome-screen');
            const suggestions = body.querySelector('.vest-suggestions');
            if (welcome) { welcome.style.display = 'none'; }
            if (suggestions) { suggestions.style.display = 'none'; }

            // User bubble
            const userMsg = document.createElement('div');
            userMsg.className = 'vest-msg user';
            userMsg.innerHTML = `<div class="vest-bubble">${escapeHtml(text)}</div>`;
            body.appendChild(userMsg);

            // AI placeholder bubble
            const aiMsg = document.createElement('div');
            aiMsg.className = 'vest-msg ai';
            aiMsg.innerHTML = `
                <div class="vest-msg-avatar"><img src="/images/VestLogo.png" alt="Vest" /></div>
                <div class="vest-bubble" style="opacity:0.6;font-style:italic;">
                    Vest AI is coming soon — stay tuned! 🚀
                </div>`;
            body.appendChild(aiMsg);
            body.scrollTop = body.scrollHeight;
        }

        function escapeHtml(str) {
            return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }
    </script>
