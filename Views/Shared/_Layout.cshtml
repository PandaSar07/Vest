@{
    var fluidMain = ViewData["FluidMain"] as bool? == true;
    var navCtrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var navAct = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var isLoggedIn = Context.Session.GetString("UserId") != null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Vest</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Vest.styles.css" asp-append-version="true" />
    <link rel="icon" type="image/png" href="~/images/favicon-32x32.png" />
    @await RenderSectionAsync("Head", required: false)
    <script>
        const theme = localStorage.getItem('theme');
        if (theme === 'light') {
            document.documentElement.setAttribute('data-theme', 'light');
        }
    </script>
    <style>
        /* ── Profile avatar ── */
        .nav-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--accent-color) 0%, #0ea5e9 100%);
            color: #0a0e1a;
            font-weight: 800;
            font-size: 0.78rem;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            letter-spacing: 0.5px;
            border: 2px solid rgba(0,194,255,0.3);
        }

        .nav-avatar-lg {
            width: 42px;
            height: 42px;
            font-size: 1rem;
        }

        .nav-profile-toggle {
            gap: 0.5rem;
            cursor: pointer;
        }

        .nav-username {
            font-size: 0.88rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        /* ── Profile dropdown ── */
        .nav-dropdown {
            background: rgba(10, 15, 25, 0.97);
            border: 1px solid rgba(0, 194, 255, 0.15);
            border-radius: 14px;
            backdrop-filter: blur(16px);
            padding: 0.5rem;
            min-width: 220px;
            box-shadow: 0 20px 60px -10px rgba(0, 0, 0, 0.7), 0 0 0 1px rgba(255,255,255,0.03);
            margin-top: 0.4rem;
        }

        .nav-dropdown-header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.6rem 0.75rem 0.8rem;
        }

        .nav-dropdown-name {
            font-weight: 700;
            font-size: 0.9rem;
            color: var(--text-primary);
            line-height: 1.2;
        }

        .nav-dropdown-email {
            font-size: 0.72rem;
            color: var(--text-secondary);
            margin-top: 2px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 150px;
        }

        .nav-divider {
            border-color: rgba(255, 255, 255, 0.06);
            margin: 0.25rem 0.5rem;
        }

        .nav-dropdown-item {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            padding: 0.55rem 0.75rem;
            border-radius: 9px;
            font-size: 0.84rem;
            color: var(--text-secondary) !important;
            transition: background 0.15s, color 0.15s;
            background: transparent;
            border: none;
            width: 100%;
            text-align: left;
            text-decoration: none;
            cursor: pointer;
        }

        .nav-dropdown-item:hover {
            background: rgba(0, 194, 255, 0.08);
            color: var(--text-primary) !important;
        }

        .nav-dropdown-item svg {
            flex-shrink: 0;
            opacity: 0.6;
        }

        .nav-dropdown-item:hover svg {
            opacity: 1;
        }

        .nav-logout-btn:hover {
            background: rgba(239, 68, 68, 0.1) !important;
            color: #ef4444 !important;
        }

        /* ── SaaS nav search ── */
        .nav-search-wrap {
            position: relative;
            width: 100%;
            max-width: 390px;
            margin: 0 1rem;
        }

        .nav-search-input {
            width: 100%;
            border: 1px solid rgba(255,255,255,0.12);
            background: rgba(12, 18, 30, 0.86);
            color: var(--text-primary);
            border-radius: 12px;
            padding: 0.58rem 0.9rem 0.58rem 2.3rem;
            font-size: 0.86rem;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

        .nav-search-input:focus {
            outline: none;
            border-color: rgba(0, 194, 255, 0.75);
            box-shadow: 0 0 0 3px rgba(0, 194, 255, 0.2);
        }

        .nav-search-icon {
            position: absolute;
            top: 50%;
            left: 0.78rem;
            transform: translateY(-50%);
            width: 14px;
            height: 14px;
            color: var(--text-secondary);
            pointer-events: none;
            opacity: 0.9;
        }

        .nav-search-dropdown {
            position: absolute;
            left: 0;
            right: 0;
            top: calc(100% + 8px);
            background: rgba(8, 13, 24, 0.97);
            border: 1px solid rgba(0, 194, 255, 0.2);
            border-radius: 12px;
            padding: 0.35rem;
            box-shadow: 0 18px 45px -18px rgba(0,0,0,0.9);
            backdrop-filter: blur(14px);
            z-index: 1050;
            display: none;
            max-height: 280px;
            overflow: auto;
        }

        .nav-search-dropdown.show {
            display: block;
        }

        .nav-search-item {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.65rem;
            border: none;
            background: transparent;
            color: var(--text-primary);
            border-radius: 8px;
            font-size: 0.83rem;
            padding: 0.52rem 0.6rem;
            text-align: left;
            cursor: pointer;
        }

        .nav-search-item:hover,
        .nav-search-item.active {
            background: rgba(0, 194, 255, 0.12);
        }

        .nav-search-symbol {
            font-weight: 700;
            letter-spacing: 0.2px;
        }

        .nav-search-name {
            color: var(--text-secondary);
            font-size: 0.76rem;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            max-width: 170px;
        }

        .nav-quick-chip {
            border: 1px solid rgba(255,255,255,0.14);
            background: rgba(255,255,255,0.03);
            color: var(--text-secondary);
            border-radius: 999px;
            font-size: 0.74rem;
            padding: 0.22rem 0.58rem;
            text-decoration: none;
            transition: all 0.2s ease;
        }

        .nav-quick-chip:hover {
            border-color: rgba(0, 194, 255, 0.6);
            color: var(--text-primary);
        }

        @@media (max-width: 992px) {
            .nav-search-wrap {
                margin: 0.6rem 0;
                max-width: none;
            }
        }

        @@media (max-width: 575.98px) {
            /* AI chat panel — fit small screens */
            #vest-ai-chat {
                width: calc(100vw - 20px) !important;
                right: 10px !important;
                left: 10px !important;
                bottom: 86px !important;
                max-height: 72vh !important;
                border-radius: 16px !important;
            }
            /* FAB — smaller and tucked in */
            #vest-ai-fab {
                bottom: 16px !important;
                right: 16px !important;
                width: 50px !important;
                height: 50px !important;
            }
            #vest-ai-fab img {
                width: 32px !important;
                height: 32px !important;
            }
        }

        /* Remove default Bootstrap dropdown arrow */
        .nav-profile-toggle.dropdown-toggle::after { display: none; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="@(isLoggedIn ? "Dashboard" : "Home")" asp-action="Index">
                    <img src="~/images/vest-rocket.png" alt="" class="navbar-logo" width="36" height="35" style="object-fit:contain;" />
                    <span class="vest-brand-label">Vest</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <div class="d-flex flex-column flex-lg-row align-items-lg-center flex-grow-1 gap-lg-2">
