        function vestScrollThreadToBottom() {
            requestAnimationFrame(() => {
                requestAnimationFrame(() => {
                    chatThreadEl.scrollTop = chatThreadEl.scrollHeight;
                });
            });
        }

        function vestHideWelcome() {
            const welcome = document.getElementById('vest-welcome-screen');
            if (welcome) welcome.style.display = 'none';
        }

        function vestSetChoicesDisabled(disabled) {
            guidedChoicesEl.querySelectorAll('.vest-suggestion-btn').forEach((b) => {
                b.disabled = disabled;
            });
        }

        function vestAppendUserBubble(text) {
            const row = document.createElement('div');
            row.className = 'vest-msg user';
            const bubble = document.createElement('div');
            bubble.className = 'vest-bubble';
            bubble.textContent = text;
            row.appendChild(bubble);
            chatThreadEl.appendChild(row);
        }

        function vestAppendTypingIndicator() {
            const row = document.createElement('div');
            row.className = 'vest-msg ai vest-typing-row';
            const av = document.createElement('div');
            av.className = 'vest-msg-avatar';
            const img = document.createElement('img');
            img.src = '/images/vest-rocket.png';
            img.alt = '';
            av.appendChild(img);
            const bubble = document.createElement('div');
            bubble.className = 'vest-bubble vest-typing-bubble';
            const wrap = document.createElement('span');
            wrap.className = 'vest-typing-dots';
            for (let i = 0; i < 3; i++) wrap.appendChild(document.createElement('span'));
            bubble.appendChild(wrap);
            row.appendChild(av);
            row.appendChild(bubble);
            chatThreadEl.appendChild(row);
            vestScrollThreadToBottom();
            return row;
        }

        function vestAppendAiBubble(text) {
            const row = document.createElement('div');
            row.className = 'vest-msg ai';
            const av = document.createElement('div');
            av.className = 'vest-msg-avatar';
            const img = document.createElement('img');
            img.src = '/images/vest-rocket.png';
            img.alt = 'Vest';
            av.appendChild(img);
            const bubble = document.createElement('div');
            bubble.className = 'vest-bubble';
            bubble.textContent = text;
            row.appendChild(av);
            row.appendChild(bubble);
            chatThreadEl.appendChild(row);
        }

        function vestRenderChoices(optionList, isRoot) {
            if (guidedLabelEl) {
                guidedLabelEl.textContent = isRoot
                    ? (vestGuidedTurnCount > 0 ? 'Pick another topic' : 'Pick a topic')
                    : 'Continue the conversation';
            }
            guidedChoicesEl.innerHTML = '';
            optionList.forEach((item) => {
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'vest-suggestion-btn';
                const ic = document.createElement('span');
                ic.className = 'vest-sug-icon';
                ic.textContent = item.icon || '💬';
                const lab = document.createElement('span');
                lab.textContent = item.question;
                btn.appendChild(ic);
                btn.appendChild(lab);
                btn.addEventListener('click', () => vestOnGuidedChoice(item));
                guidedChoicesEl.appendChild(btn);
            });
        }

        function vestAbortPendingReply() {
            if (vestReplyTimer != null) {
                clearTimeout(vestReplyTimer);
                vestReplyTimer = null;
                const typing = chatThreadEl.querySelector('.vest-typing-row');
                if (typing) {
                    const prev = typing.previousElementSibling;
                    typing.remove();
                    if (prev && prev.classList.contains('vest-msg') && prev.classList.contains('user')) {
                        prev.remove();
                    }
                }
            } else {
                chatThreadEl.querySelectorAll('.vest-typing-row').forEach((n) => n.remove());
            }
            vestGuidedBusy = false;
            vestSetChoicesDisabled(false);
            if (!chatThreadEl.querySelector('.vest-msg')) {
                const welcome = document.getElementById('vest-welcome-screen');
                if (welcome) welcome.style.display = '';
            }
        }

        function vestOnGuidedChoice(item) {
            if (vestGuidedBusy) return;
            vestGuidedBusy = true;
            vestSetChoicesDisabled(true);
            vestHideWelcome();
            vestAppendUserBubble(item.question);
            vestScrollThreadToBottom();

            const typingRow = vestAppendTypingIndicator();
            vestReplyTimer = window.setTimeout(() => {
                vestReplyTimer = null;
                typingRow.remove();
                vestAppendAiBubble(item.answer);
                const next = item.followUps && item.followUps.length ? item.followUps : VEST_GUIDED_ROOT;
                vestGuidedTurnCount++;
                vestRenderChoices(next, next === VEST_GUIDED_ROOT);
                vestGuidedBusy = false;
                vestScrollThreadToBottom();
            }, 320);
        }

        vestRenderChoices(VEST_GUIDED_ROOT, true);

        fab.addEventListener('click', () => {
            const isOpen = chatPanel.classList.contains('vest-open');
            if (isOpen) {
                vestAbortPendingReply();
                chatPanel.style.opacity = '0';
                chatPanel.style.transform = 'translateY(12px) scale(0.97)';
                setTimeout(() => { chatPanel.classList.remove('vest-open'); }, 180);
            } else {
                if (fab.dataset.dragged === 'true' && chatPanel.dataset.dragged !== 'true') {
                    const rect = fab.getBoundingClientRect();
                    const chatWidth = 370;
                    const vh = window.innerHeight;
                    const vw = window.innerWidth;

                    chatPanel.style.right = 'auto';
                    chatPanel.style.bottom = 'auto';

                    let left = rect.left + rect.width - chatWidth;
                    let top = rect.top - 570;

                    if (left < 10) left = 10;
                    if (left + chatWidth > vw - 10) left = vw - chatWidth - 10;
                    if (top < 10) top = 10;
                    if (top + 560 > vh - 10) top = vh - 560 - 10;

                    chatPanel.style.left = left + 'px';
                    chatPanel.style.top = top + 'px';
                }

                chatPanel.classList.add('vest-open');
                requestAnimationFrame(() => {
                    chatPanel.style.opacity = '1';
                    chatPanel.style.transform = 'translateY(0) scale(1)';
                });
                vestScrollThreadToBottom();
            }
        });

        closeBtn.addEventListener('click', () => {
            vestAbortPendingReply();
            chatPanel.style.opacity = '0';
            chatPanel.style.transform = 'translateY(12px) scale(0.97)';
            setTimeout(() => { chatPanel.classList.remove('vest-open'); }, 180);
        });

        // ── Unified Draggable Logic ──
        (function () {
            function makeDraggable(el, handle, options = {}) {
                let dragging = false;
                let startX, startY, origX, origY;
                let hasMoved = false;

                const start = (e) => {
                    if (e.target.closest('#vest-ai-close')) return;
                    
                    const clientX = e.type === 'touchstart' ? e.touches[0].clientX : e.clientX;
                    const clientY = e.type === 'touchstart' ? e.touches[0].clientY : e.clientY;

                    dragging = true;
                    hasMoved = false;
                    startX = clientX;
                    startY = clientY;

                    const rect = el.getBoundingClientRect();
                    origX = rect.left;
                    origY = rect.top;

                    el.style.transition = 'none';
                    el.style.right = 'auto';
                    el.style.bottom = 'auto';
                    el.style.left = origX + 'px';
                    el.style.top = origY + 'px';
                    
                    document.body.style.userSelect = 'none';
                    document.body.style.touchAction = 'none';
                };

                const move = (e) => {
                    if (!dragging) return;
                    
                    const clientX = e.type === 'touchmove' ? e.touches[0].clientX : e.clientX;
                    const clientY = e.type === 'touchmove' ? e.touches[0].clientY : e.clientY;

                    const dx = clientX - startX;
                    const dy = clientY - startY;

                    if (Math.abs(dx) > 5 || Math.abs(dy) > 5) {
                        hasMoved = true;
                    }

                    if (hasMoved) {
                        el.style.left = (origX + dx) + 'px';
                        el.style.top = (origY + dy) + 'px';
                        if (options.onDrag) options.onDrag(el, origX + dx, origY + dy);
                    }
                };

                const stop = () => {
                    if (!dragging) return;
                    dragging = false;
                    el.style.transition = '';
                    document.body.style.userSelect = '';
                    document.body.style.touchAction = '';
                    if (options.onStop) options.onStop(hasMoved);
                };

                handle.addEventListener('mousedown', start);
                handle.addEventListener('touchstart', start, { passive: false });
                document.addEventListener('mousemove', move);
                document.addEventListener('touchmove', move, { passive: false });
                document.addEventListener('mouseup', stop);
                document.addEventListener('touchend', stop);

                return {
                    wasDragged: () => hasMoved
                };
            }

            // Drag for Chat Panel
            const chatHandle = document.getElementById('vest-drag-handle');
            makeDraggable(chatPanel, chatHandle, {
                onStop: (moved) => {
                    if (moved) chatPanel.dataset.dragged = 'true';
                }
            });

            // FAB remains fixed; only the chat panel is draggable.
        })();
    </script>
</body>
</html>
