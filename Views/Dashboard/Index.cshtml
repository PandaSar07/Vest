@{
    ViewData["Title"] = "Dashboard";
    var dashUsername = ViewContext.HttpContext.Session.GetString("Username") ?? "Trader";
}

<style>
    .dash-grid {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 1.5rem;
        margin-bottom: 1.5rem;
    }

    @@media (max-width: 900px) { .dash-grid { grid-template-columns: 1fr; } }

    .dash-card {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: var(--radius-md);
        backdrop-filter: var(--glass-blur);
        padding: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .dash-section-title {
        font-family: var(--font-brand);
        font-size: 1rem;
        letter-spacing: 0.5px;
        background: linear-gradient(135deg, #fff 0%, #94a3b8 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 1rem;
    }

    .value-xl {
        font-size: 2.2rem;
        font-weight: 800;
        font-variant-numeric: tabular-nums;
        line-height: 1.1;
        background: linear-gradient(135deg, #fff 0%, #94a3b8 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .sub-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; margin-top: 1rem; }

    .sub-tile {
        background: rgba(255,255,255,0.03);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-sm);
        padding: 0.85rem 1rem;
    }

    .tile-label { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 1px; color: var(--text-secondary); font-weight: 600; }
    .tile-value { font-size: 1rem; font-weight: 700; font-variant-numeric: tabular-nums; }
    .up   { color: var(--success-color); }
    .down { color: var(--danger-color); }

    .charts-row {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 1.5rem;
        margin-bottom: 1.5rem;
    }

    @@media (max-width: 860px) { .charts-row { grid-template-columns: 1fr; } }

    .holdings-table th, .holdings-table td { padding: 0.9rem 1rem !important; font-size: 0.88rem; }
    .holdings-table tr:hover td { background: rgba(255,255,255,0.025); }

    .cancel-btn {
        border: 1px solid rgba(239,68,68,0.4);
        background: transparent;
        color: #ef4444;
        border-radius: 6px;
        padding: 0.25rem 0.6rem;
        font-size: 0.75rem;
        cursor: pointer;
        transition: var(--transition);
    }
    .cancel-btn:hover { background: rgba(239,68,68,0.15); }
</style>

<div class="py-4">
    <h1 class="display-5 mb-1">Dashboard</h1>
    <p class="text-secondary mb-4">Welcome back, <strong>@dashUsername</strong>. Here's your portfolio at a glance.</p>

    <!-- Summary + Holdings -->
    <div class="dash-grid">
        <!-- Left: value summary -->
        <div class="dash-card">
            <p class="dash-section-title">Portfolio Value</p>
            <div class="value-xl" id="dashTotalValue">—</div>
            <div class="sub-grid">
                <div class="sub-tile">
                    <div class="tile-label">Cash</div>
                    <div class="tile-value" id="dashCash">—</div>
                </div>
                <div class="sub-tile">
                    <div class="tile-label">Invested</div>
                    <div class="tile-value" id="dashStockValue">—</div>
                </div>
                <div class="sub-tile">
                    <div class="tile-label">Total Gain/Loss</div>
                    <div class="tile-value" id="dashGainLoss">—</div>
                </div>
                <div class="sub-tile">
                    <div class="tile-label">Positions</div>
                    <div class="tile-value" id="dashPositions">—</div>
                </div>
            </div>
        </div>

        <!-- Right: holdings table -->
        <div class="dash-card">
            <p class="dash-section-title">Holdings</p>
            <div class="table-responsive">
                <table class="table holdings-table mb-0">
                    <thead>
                        <tr><th>Symbol</th><th>Shares</th><th>Avg Cost</th><th>Live Price</th><th>Mkt Value</th><th>Gain/Loss</th></tr>
                    </thead>
                    <tbody id="holdingsBody">
                        <tr><td colspan="6" style="text-align:center;color:var(--text-secondary);">Loading…</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Performance Chart + Sector Donut -->
    <div class="charts-row">
        <div class="dash-card" style="margin-bottom:0;">
            <p class="dash-section-title">Portfolio Performance</p>
            <canvas id="perfChart" height="160"></canvas>
            <p id="perfMsg" style="color:var(--text-secondary);font-size:0.85rem;text-align:center;display:none;">
                Visit this page daily to build up your performance history.
            </p>
        </div>
        <div class="dash-card" style="margin-bottom:0;">
            <p class="dash-section-title">Sector Allocation</p>
            <canvas id="sectorChart" height="200"></canvas>
            <p id="sectorMsg" style="color:var(--text-secondary);font-size:0.85rem;text-align:center;display:none;">No holdings yet.</p>
        </div>
    </div>

    <!-- Pending Limit Orders -->
    <div class="dash-card mt-4" id="ordersSection" style="display:none;">
        <p class="dash-section-title">Pending Limit Orders</p>
        <div class="table-responsive">
            <table class="table mb-0">
                <thead><tr><th>Symbol</th><th>Action</th><th>Shares</th><th>Limit Price</th><th>Placed</th><th></th></tr></thead>
                <tbody id="ordersBody"></tbody>
            </table>
        </div>
    </div>

    <!-- Recent Trades -->
    <div class="dash-card mt-4">
        <p class="dash-section-title">Recent Trades</p>
        <div class="table-responsive">
            <table class="table mb-0">
                <thead><tr><th>Date</th><th>Symbol</th><th>Action</th><th>Shares</th><th>Price</th><th>Total</th></tr></thead>
                <tbody id="tradesBody"><tr><td colspan="6" style="text-align:center;color:var(--text-secondary);">Loading…</td></tr></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
    const fmt = (n, d = 2) =>
        n == null ? '—' : Number(n).toLocaleString('en-US', { minimumFractionDigits: d, maximumFractionDigits: d });
    const parseApiDate = (value) => {
        if (!value) return null;
        if (typeof value === 'string' && /^\d{4}-\d{2}-\d{2}$/.test(value)) {
            const [y, m, d] = value.split('-').map(Number);
            return new Date(y, m - 1, d);
        }
        const dt = new Date(value);
        return Number.isNaN(dt.getTime()) ? null : dt;
    };

    // ── Summary + Charts ────────────────────────────────────────────────────
    async function loadSummary() {
        try {
            const r = await fetch('/portfolio/summary');
            if (r.status === 401) { window.location = '/Home/Log'; return; }
            if (!r.ok) return;
            const d = await r.json();

            document.getElementById('dashTotalValue').textContent = '$' + fmt(d.totalValue);
            document.getElementById('dashCash').textContent        = '$' + fmt(d.cash);
            document.getElementById('dashStockValue').textContent  = '$' + fmt(d.stockValue);
            document.getElementById('dashPositions').textContent   = d.holdings.length;

            const totalCost = d.holdings.reduce((s, h) => s + h.shares * h.avgCost, 0);
            const gainLoss  = d.stockValue - totalCost;
            const glEl = document.getElementById('dashGainLoss');
            glEl.textContent = (gainLoss >= 0 ? '+$' : '-$') + fmt(Math.abs(gainLoss));
            glEl.className = 'tile-value ' + (gainLoss >= 0 ? 'up' : 'down');

            // Holdings table
            const tbody = document.getElementById('holdingsBody');
            if (!d.holdings.length) {
                tbody.innerHTML = `<tr><td colspan="6" style="text-align:center;color:var(--text-secondary);">No positions yet — <a href="/Stocks" style="color:var(--accent-color)">start trading</a>.</td></tr>`;
            } else {
                tbody.innerHTML = d.holdings.map(h => {
                    const glClass = h.gainLoss >= 0 ? 'up' : 'down';
                    const sign    = h.gainLoss >= 0 ? '+' : '';
                    const isOption = typeof h.symbol === 'string' && h.symbol.includes('|OPT|');
                    const displaySymbol = isOption
                        ? h.symbol.replace('|OPT|', ' OPT ').replaceAll('|', ' ')
                        : h.symbol;
                    const qtyLabel = isOption ? `${fmt(h.shares, 0)} ctr` : fmt(h.shares, 4);
                    return `<tr>
                        <td><a href="/Stocks?symbol=${h.symbol}" style="color:var(--accent-color);font-weight:700;">${displaySymbol}</a></td>
                        <td>${qtyLabel}</td>
                        <td>$${fmt(h.avgCost)}</td>
                        <td>$${fmt(h.livePrice)}</td>
                        <td>$${fmt(h.marketValue)}</td>
                        <td class="${glClass}">${sign}$${fmt(Math.abs(h.gainLoss))} (${sign}${fmt(h.gainLossPct)}%)</td>
                    </tr>`;
                }).join('');
            }

            // Sector donut
            renderSectorChart(d.holdings);
        } catch(e) { console.warn('Summary error', e); }
    }

    // ── Performance Chart ────────────────────────────────────────────────────
    async function loadPerfChart() {
        try {
            const r = await fetch('/portfolio/snapshots?days=60');
            if (!r.ok) return;
            const snaps = await r.json();
            if (!Array.isArray(snaps) || snaps.length < 2) {
                document.getElementById('perfMsg').style.display = 'block';
                return;
            }

            // Support both snake_case and camelCase payload shapes.
            const normalized = snaps
                .map(s => ({
                    value: Number(s.value),
                    date: parseApiDate(s.snappedAt ?? s.snapped_at)
                }))
                .filter(s => Number.isFinite(s.value) && s.date);

            // Ensure stable chronological plotting.
            normalized.sort((a, b) => a.date - b.date);

            const validSnaps = normalized;
            if (validSnaps.length < 2) {
                document.getElementById('perfMsg').style.display = 'block';
                return;
            }
            const labels = validSnaps.map(s => s.date.toLocaleDateString('en-US', { month:'short', day:'numeric' }));
            const values = validSnaps.map(s => s.value);
            const isUp   = values[values.length - 1] >= values[0];
            const color  = isUp ? '#10b981' : '#ef4444';

            new Chart(document.getElementById('perfChart'), {
                type: 'line',
                data: {
                    labels,
                    datasets: [{
                        data: values,
                        borderColor: color,
                        backgroundColor: color.replace(')', ',0.08)').replace('rgb', 'rgba'),
                        fill: true,
                        tension: 0.4,
                        pointRadius: 0,
                        borderWidth: 2,
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false }, tooltip: {
                        callbacks: { label: ctx => '$' + fmt(ctx.parsed.y) }
                    }},
                    scales: {
                        x: { grid: { color:'rgba(255,255,255,0.04)' }, ticks: { color:'#64748b', maxTicksLimit:8 }},
                        y: { grid: { color:'rgba(255,255,255,0.04)' }, ticks: { color:'#64748b', callback: v => '$' + fmt(v) }}
                    }
                }
            });
        } catch(e) { console.warn('Perf chart error', e); }
    }

    // ── Sector Donut ─────────────────────────────────────────────────────────
    function renderSectorChart(holdings) {
        if (!holdings.length) {
            document.getElementById('sectorMsg').style.display = 'block';
            return;
        }
        const sectorMap = {};
        holdings.forEach(h => {
            const s = h.sector || 'Other';
            sectorMap[s] = (sectorMap[s] || 0) + h.marketValue;
        });
        const labels = Object.keys(sectorMap);
        const values = Object.values(sectorMap);
        const palette = ['#38bdf8','#10b981','#f59e0b','#ef4444','#8b5cf6','#ec4899','#f97316','#06b6d4'];

        new Chart(document.getElementById('sectorChart'), {
            type: 'doughnut',
            data: {
                labels,
                datasets: [{ data: values, backgroundColor: palette.slice(0, labels.length), borderWidth: 2, borderColor: 'rgba(0,0,0,0.3)' }]
            },
            options: {
                responsive: true,
                cutout: '65%',
                plugins: {
                    legend: { position: 'bottom', labels: { color:'#94a3b8', font:{ size:11 }, padding:12 }},
                    tooltip: { callbacks: { label: ctx => `${ctx.label}: $${fmt(ctx.parsed)}` }}
                }
            }
        });
    }

    // ── Pending Orders ────────────────────────────────────────────────────────
    async function loadOrders() {
        try {
            const r = await fetch('/portfolio/orders');
            if (!r.ok) return;
            const orders = await r.json();
            if (!orders.length) return;

            document.getElementById('ordersSection').style.display = 'block';
            document.getElementById('ordersBody').innerHTML = orders.map(o => `
                <tr>
                    <td><a href="/Stocks?symbol=${o.symbol}" style="color:var(--accent-color);font-weight:700;">${o.symbol}</a></td>
                    <td><span class="badge ${o.action==='BUY'?'badge-buy':'badge-sell'}">${o.action}</span></td>
                    <td>${fmt(o.shares, 4)}</td>
                    <td>$${fmt(o.limitPrice)}</td>
                    <td class="small">${new Date(o.createdAt).toLocaleDateString()}</td>
                    <td><button class="cancel-btn" onclick="cancelOrder(${o.id}, this)">Cancel</button></td>
                </tr>`).join('');
        } catch(e) { console.warn('Orders error', e); }
    }

    async function cancelOrder(id, btn) {
        btn.disabled = true;
        const r = await fetch(`/portfolio/order/${id}`, { method:'DELETE' });
        if (r.ok) btn.closest('tr').remove();
        else { btn.disabled = false; alert('Failed to cancel order.'); }
    }

    // ── Trades ────────────────────────────────────────────────────────────────
    async function loadTrades() {
        try {
            const r = await fetch('/portfolio/trades?limit=15');
            if (!r.ok) return;
            const trades = await r.json();
            const tbody  = document.getElementById('tradesBody');
            if (!trades.length) {
                tbody.innerHTML = `<tr><td colspan="6" style="text-align:center;color:var(--text-secondary);">No trades yet.</td></tr>`;
                return;
            }
            tbody.innerHTML = trades.map(t => {
                const badge = t.action === 'BUY'
                    ? `<span class="badge badge-buy">BUY</span>`
                    : `<span class="badge badge-sell">SELL</span>`;
                const date = new Date(t.tradedAt).toLocaleString('en-US', {
                    month:'short', day:'numeric', year:'numeric', hour:'numeric', minute:'2-digit'
                });
                return `<tr>
                    <td class="small">${date}</td>
                    <td><a href="/Stocks?symbol=${t.symbol}" style="color:var(--accent-color);font-weight:700;">${t.symbol}</a></td>
                    <td>${badge}</td>
                    <td>${fmt(t.shares, 4)}</td>
                    <td>$${fmt(t.price)}</td>
                    <td class="fw-bold">$${fmt(t.total)}</td>
                </tr>`;
            }).join('');
        } catch(e) { console.warn('Trades error', e); }
    }

    loadSummary();
    loadPerfChart();
    loadOrders();
    loadTrades();
</script>
}
